<file path="templates/news/news_list.html">
{% extends 'base.html' %}

{% block title %}Новости кафедры{% endblock %}
{% block breadcrumbs %}
    <li class="breadcrumb-item active" aria-current="page">Новости</li>
{% endblock %}

{% block content %}
<div class="row mt-4">
    <div class="col-12">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="bi bi-newspaper"></i> Новости кафедры</span>
                {% if user.role == 'DEAN' %}
                    <a href="{% url 'news:create' %}" class="btn btn-success btn-sm">
                        <i class="bi bi-plus-circle"></i> Добавить новость
                    </a>
                {% endif %}
            </div>
            <div class="card-body">
                
                <div class="mb-4">
                    <div class="btn-group" role="group">
                        <a href="{% url 'news:list' %}" class="btn btn-sm {% if not selected_category %}btn-primary{% else %}btn-outline-primary{% endif %}">
                            Все
                        </a>
                        {% for value, label in categories %}
                            <a href="{% url 'news:list' %}?category={{ value }}" 
                               class="btn btn-sm {% if selected_category == value %}btn-primary{% else %}btn-outline-primary{% endif %}">
                                {{ label }}
                            </a>
                        {% endfor %}
                    </div>
                </div>

                {% for news in news_page %}
                    <div class="card mb-3 {% if news.is_pinned %}border-warning{% endif %}">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start">
                                <div class="flex-grow-1">
                                    <h5 class="card-title">
                                        {% if news.is_pinned %}
                                            <i class="bi bi-pin-angle-fill text-warning"></i>
                                        {% endif %}
                                        <a href="{% url 'news:detail' news.id %}" class="text-decoration-none">
                                            {{ news.title }}
                                        </a>
                                    </h5>
                                    
                                    <div class="mb-2">
                                        <span class="badge bg-primary">{{ news.get_category_display }}</span>
                                        <small class="text-muted ms-2">
                                            <i class="bi bi-calendar"></i> {{ news.created_at|date:"d.m.Y H:i" }}
                                        </small>
                                        <small class="text-muted ms-2">
                                            <i class="bi bi-person"></i> {{ news.author.get_full_name }}
                                        </small>
                                        <small class="text-muted ms-2">
                                            <i class="bi bi-eye"></i> {{ news.views_count }}
                                        </small>
                                        <small class="text-muted ms-2">
                                            <i class="bi bi-chat"></i> {{ news.comments.count }}
                                        </small>
                                    </div>
                                    
                                    <p class="card-text text-muted">
                                        {{ news.content|truncatewords:50 }}
                                    </p>
                                    
                                    {% if news.image %}
                                        <img src="{{ news.image.url }}" class="img-fluid rounded mt-2" style="max-height: 200px;" alt="{{ news.title }}">
                                    {% endif %}
                                </div>
                            </div>
                            
                            <div class="mt-3">
                                <a href="{% url 'news:detail' news.id %}" class="btn btn-sm btn-primary">
                                    <i class="bi bi-arrow-right"></i> Читать далее
                                </a>
                                
                                {% if user.role == 'DEAN' %}
                                    <a href="{% url 'news:edit' news.id %}" class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-pencil"></i> Редактировать
                                    </a>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                {% empty %}
                    <div class="alert alert-info text-center">
                        <i class="bi bi-info-circle"></i> Новостей пока нет
                    </div>
                {% endfor %}

                {% if news_page.has_other_pages %}
                    <nav>
                        <ul class="pagination justify-content-center">
                            {% if news_page.has_previous %}
                                <li class="page-item">
                                    <a class="page-link" href="?page={{ news_page.previous_page_number }}{% if selected_category %}&category={{ selected_category }}{% endif %}">
                                        Предыдущая
                                    </a>
                                </li>
                            {% endif %}
                            
                            {% for num in news_page.paginator.page_range %}
                                <li class="page-item {% if news_page.number == num %}active{% endif %}">
                                    <a class="page-link" href="?page={{ num }}{% if selected_category %}&category={{ selected_category }}{% endif %}">
                                        {{ num }}
                                    </a>
                                </li>
                            {% endfor %}
                            
                            {% if news_page.has_next %}
                                <li class="page-item">
                                    <a class="page-link" href="?page={{ news_page.next_page_number }}{% if selected_category %}&category={{ selected_category }}{% endif %}">
                                        Следующая
                                    </a>
                                </li>
                            {% endif %}
                        </ul>
                    </nav>
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endblock %}
</file>

<file path="templates/schedule/auto_schedule.html">
{% extends 'base.html' %}
{% block title %}Умная генерация расписания{% endblock %}

{% block content %}
<div class="row mt-4">
    <div class="col-lg-10 mx-auto">
        <div class="card shadow border-primary">
            <div class="card-header bg-primary text-white d-flex align-items-center">
                <i class="bi bi-robot fs-4 me-2"></i>
                <h5 class="mb-0">AI Timetabling: Мультистартовая генерация</h5>
            </div>
            <div class="card-body bg-light">
                <div class="alert alert-info">
                    <i class="bi bi-cpu"></i> Алгоритм сгенерирует несколько вариантов расписания и выберет наилучший, минимизируя окна у студентов и подбирая оптимальные аудитории.
                </div>

                <form method="post">
                    {% csrf_token %}

                    <div class="row g-4 mb-4">
                        <div class="col-md-6">
                            <div class="card h-100 border-0 shadow-sm">
                                <div class="card-header bg-white fw-bold text-dark"><i class="bi bi-gear"></i> 1. Базовые параметры</div>
                                <div class="card-body">
                                    <div class="mb-3">
                                        <label class="form-label fw-bold">Семестр *</label>
                                        <select name="semester" class="form-select border-primary" required>
                                            <option value="">-- Выберите семестр --</option>
                                            {% for sem in semesters %}
                                                <option value="{{ sem.id }}">{{ sem.name }} ({{ sem.academic_year }}) - {{ sem.get_shift_display }}</option>
                                            {% endfor %}
                                        </select>
                                    </div>
                                    <div class="form-check form-switch mt-4">
                                        <input class="form-check-input" type="checkbox" name="clear_existing" id="clearExisting" checked>
                                        <label class="form-check-label text-danger fw-bold" for="clearExisting">Очистить старое расписание</label>
                                        <div class="form-text">Удалит текущее расписание выбранных групп перед созданием нового.</div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="card h-100 border-0 shadow-sm">
                                <div class="card-header bg-white fw-bold text-dark d-flex justify-content-between align-items-center">
                                    <span><i class="bi bi-sliders"></i> 2. Тонкая настройка ИИ</span>
                                    <a href="{% url 'schedule:manage_teacher_availability' %}" target="_blank" class="btn btn-sm btn-outline-danger">
                                        <i class="bi bi-calendar-x"></i> Выходные преподавателей
                                    </a>
                                </div>
                                <div class="card-body">

                                    <div class="mb-3">
                                        <label class="form-label fw-bold small text-primary">Лимит вместимости кабинетов</label>
                                        <select name="overflow_mode" class="form-select form-select-sm">
                                            <option value="0">Строго (0% переполнения)</option>
                                            <option value="1">Мягко (+25% переполнения)</option>
                                            <option value="2" selected>Экстремально (+50% переполнения)</option>
                                            <option value="3">Игнорировать вместимость (сажать куда угодно)</option>
                                        </select>
                                    </div>

                                    <div class="form-check form-switch mb-2">
                                        <input class="form-check-input" type="checkbox" name="strict_room_types" id="strictRoomTypes">
                                        <label class="form-check-label fw-bold text-warning" for="strictRoomTypes">Строгие типы аудиторий</label>
                                        <div class="form-text" style="font-size: 0.7rem;">Если выключено, ИИ сможет поставить Лекцию в кабинет Практики, если больше нет мест.</div>
                                    </div>

                                    <div class="form-check form-switch mb-3">
                                        <input class="form-check-input" type="checkbox" name="avoid_gaps" id="avoidGaps" checked>
                                        <label class="form-check-label fw-bold text-success" for="avoidGaps">Минимизировать "окна"</label>
                                    </div>

                                    <div class="mb-2">
                                        <label class="form-label fw-bold small">Глубина поиска (Кол-во вариантов)</label>
                                        <input type="number" name="iterations" class="form-control form-control-sm border-primary" value="50" min="1" max="10000">
                                        <div class="form-text" style="font-size: 0.7rem;">
                                            Больше вариантов = лучше качество, но дольше расчет.<br>
                                            <em>50 — оптимально (до 5 сек). 1000 — глубокий поиск (до 1 мин).</em>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <h6 class="fw-bold text-dark mb-3"><i class="bi bi-funnel"></i> 3. Ограничения данных (Для кого строим)</h6>
                    <div class="row g-4 mb-4">
                        <div class="col-md-4">
                            <div class="card h-100 border-0 shadow-sm">
                                <div class="card-header bg-white fw-bold"><i class="bi bi-people text-primary"></i> Группы *</div>
                                <div class="card-body p-2" style="max-height: 200px; overflow-y: auto;">
                                    <div class="form-check border-bottom pb-2 mb-2">
                                        <input class="form-check-input" type="checkbox" id="selectAllGroups" onchange="toggleCheckboxes('group-cb', this.checked)">
                                        <label class="form-check-label fw-bold">Выбрать все</label>
                                    </div>
                                    {% for g in groups %}
                                    <div class="form-check">
                                        <input class="form-check-input group-cb" type="checkbox" name="groups" value="{{ g.id }}">
                                        <label class="form-check-label small">{{ g.name }} <span class="text-muted">({{ g.course }}к)</span></label>
                                    </div>
                                    {% endfor %}
                                </div>
                            </div>
                        </div>

                        <div class="col-md-4">
                            <div class="card h-100 border-0 shadow-sm">
                                <div class="card-header bg-white fw-bold"><i class="bi bi-person-video3 text-success"></i> Преподаватели</div>
                                <div class="card-body p-2" style="max-height: 200px; overflow-y: auto;">
                                    <div class="form-check border-bottom pb-2 mb-2">
                                        <input class="form-check-input" type="checkbox" id="selectAllTeachers" checked onchange="toggleCheckboxes('teacher-cb', this.checked)">
                                        <label class="form-check-label fw-bold">Все доступные</label>
                                    </div>
                                    {% for t in teachers %}
                                    <div class="form-check">
                                        <input class="form-check-input teacher-cb" type="checkbox" name="teachers" value="{{ t.id }}" checked>
                                        <label class="form-check-label small">{{ t.user.get_full_name }}</label>
                                    </div>
                                    {% endfor %}
                                </div>
                            </div>
                        </div>

                        <div class="col-md-4">
                            <div class="card h-100 border-0 shadow-sm">
                                <div class="card-header bg-white fw-bold"><i class="bi bi-door-open text-warning"></i> Кабинеты</div>
                                <div class="card-body p-2" style="max-height: 200px; overflow-y: auto;">
                                    <div class="form-check border-bottom pb-2 mb-2">
                                        <input class="form-check-input" type="checkbox" id="selectAllRooms" checked onchange="toggleCheckboxes('room-cb', this.checked)">
                                        <label class="form-check-label fw-bold">Все активные</label>
                                    </div>
                                    {% for r in rooms %}
                                    <div class="form-check">
                                        <input class="form-check-input room-cb" type="checkbox" name="rooms" value="{{ r.id }}" checked>
                                        <label class="form-check-label small">{{ r.number }} <span class="text-muted">(Вм: {{ r.capacity }}, {{ r.get_room_type_display }})</span></label>
                                    </div>
                                    {% endfor %}
                                </div>
                            </div>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary btn-lg w-100 fw-bold shadow" onclick="this.innerHTML='<span class=\'spinner-border spinner-border-sm\'></span> Идет расчет лучших вариантов...'; this.style.opacity='0.8';">
                        <i class="bi bi-magic"></i> Запустить алгоритм
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
function toggleCheckboxes(className, isChecked) {
    document.querySelectorAll('.' + className).forEach(cb => cb.checked = isChecked);
}
</script>
{% endblock %}
</file>


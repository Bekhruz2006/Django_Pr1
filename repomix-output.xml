<script>
document.getElementById('id_lecture_hours').readOnly = true;
document.getElementById('id_practice_hours').readOnly = true;
document.getElementById('id_lab_hours').readOnly = true;
document.getElementById('id_control_hours').readOnly = true;
document.getElementById('id_independent_hours').readOnly = true;

document.getElementById('id_lecture_hours').classList.add('bg-light');
document.getElementById('id_practice_hours').classList.add('bg-light');
document.getElementById('id_lab_hours').classList.add('bg-light');
document.getElementById('id_control_hours').classList.add('bg-light');
document.getElementById('id_independent_hours').classList.add('bg-light');

function addCreditTypePrompt() {
    const name = prompt("Введите название системы кредитов (например: Национальный):");
    if (!name) return;
    const hours = prompt("Сколько часов в 1 кредите этой системы?", "30");
    if (!hours) return;

    fetch('{% url "schedule:api_create_credit_type" %}', {
        method: 'POST',
        headers: {'Content-Type': 'application/json', 'X-CSRFToken': '{{ csrf_token }}'},
        body: JSON.stringify({ name: name, hours: hours })
    }).then(r => r.json()).then(data => {
        if(data.success) {
            const opt = new Option(`${data.name}`, data.id, true, true);
            opt.setAttribute('data-hours', data.hours);
            document.getElementById('id_credit_type').add(opt);
            document.getElementById('edit_credit_type').add(opt.cloneNode(true));
            calculateHours('add_');
        } else alert(data.error);
    });
}

function calculateHours(prefix) {
    const weeks = parseInt(document.getElementById(prefix + 'ui_weeks').value) || 16;
    const creditsInput = document.getElementById(prefix === 'add_' ? 'id_credits' : 'edit_credits');
    const credits = parseFloat(creditsInput.value) || 0;
    
    const ctSelect = document.getElementById(prefix === 'add_' ? 'id_credit_type' : 'edit_credit_type');
    const hoursPerCredit = ctSelect && ctSelect.options[ctSelect.selectedIndex] ? 
                           parseFloat(ctSelect.options[ctSelect.selectedIndex].getAttribute('data-hours')) : 24;

    const lecPairs = parseFloat(document.getElementById(prefix + 'ui_lec').value) || 0;
    const pracPairs = parseFloat(document.getElementById(prefix + 'ui_prac').value) || 0;
    const labPairs = parseFloat(document.getElementById(prefix + 'ui_lab').value) || 0;
    const srspPairs = parseFloat(document.getElementById(prefix + 'ui_srsp').value) || 0;

    const lecHours = Math.round(lecPairs * 2 * weeks);
    const pracHours = Math.round(pracPairs * 2 * weeks);
    const labHours = Math.round(labPairs * 2 * weeks);
    const srspHours = Math.round(srspPairs * 2 * weeks);

    const totalAuditory = lecHours + pracHours + labHours + srspHours;
    const totalCreditHours = Math.round(credits * hoursPerCredit);
    
    let srsHours = totalCreditHours - totalAuditory;
    if (srsHours < 0) srsHours = 0; 

    document.getElementById(prefix === 'add_' ? 'id_lecture_hours' : 'edit_lec_val').value = lecHours;
    document.getElementById(prefix === 'add_' ? 'id_practice_hours' : 'edit_prac_val').value = pracHours;
    document.getElementById(prefix === 'add_' ? 'id_lab_hours' : 'edit_lab_val').value = labHours;
    document.getElementById(prefix === 'add_' ? 'id_control_hours' : 'edit_srsp_val').value = srspHours;
    document.getElementById(prefix === 'add_' ? 'id_independent_hours' : 'edit_srs_val').value = srsHours;
    
    if(prefix === 'add_') {
        document.getElementById('add_total_credits_badge').innerText = `${totalCreditHours} ч. всего`;
    }
    
    const warningEl = document.getElementById(prefix + 'hours_warning');
    if (totalAuditory > totalCreditHours && credits > 0) {
        warningEl.style.display = 'block';
        warningEl.innerHTML = `<i class="bi bi-exclamation-triangle-fill"></i> Внимание: Аудиторных часов (${totalAuditory}) больше, чем выделено кредитами (${totalCreditHours})!`;
    } else {
        warningEl.style.display = 'none';
    }
}

document.querySelectorAll('.add-ui-calc').forEach(el => {
    el.addEventListener('input', () => calculateHours('add_'));
    el.addEventListener('change', () => calculateHours('add_'));
});
document.getElementById('id_credits').addEventListener('input', () => calculateHours('add_'));

document.querySelectorAll('.edit-ui-calc').forEach(el => {
    el.addEventListener('input', () => calculateHours('edit_'));
    el.addEventListener('change', () => calculateHours('edit_'));
});

function openEditModal(id, cred, lec, prac, lab, srsp, srs, cType) {
    document.getElementById('editDisciplineForm').action = `/schedule/plans/discipline/${id}/edit/`;
    document.getElementById('edit_credits').value = cred;
    document.getElementById('edit_credit_type').value = cType;
    
    const weeks = parseInt(document.getElementById('edit_ui_weeks').value) || 16;
    
    function setSelectSafe(selectId, pairs) {
        const select = document.getElementById(selectId);
        let exists = false;
        for(let i=0; i<select.options.length; i++) {
            if(parseFloat(select.options[i].value) === pairs) { exists = true; break; }
        }
        if(!exists && pairs > 0) {
            select.add(new Option(pairs + " пар", pairs));
        }
        select.value = pairs.toString();
    }

    setSelectSafe('edit_ui_lec', lec / (2 * weeks));
    setSelectSafe('edit_ui_prac', prac / (2 * weeks));
    setSelectSafe('edit_ui_lab', lab / (2 * weeks));
    setSelectSafe('edit_ui_srsp', srsp / (2 * weeks));
    
    document.getElementById('edit_lec_val').value = lec;
    document.getElementById('edit_prac_val').value = prac;
    document.getElementById('edit_lab_val').value = lab;
    document.getElementById('edit_srsp_val').value = srsp;
    document.getElementById('edit_srs_val').value = srs;
    
    calculateHours('edit_');
    new bootstrap.Modal(document.getElementById('editDisciplineModal')).show();
}

function createSubjectTemplate() {
    const nameInput = document.getElementById('newSubjectName');
    const errorDiv = document.getElementById('modalError');
    const name = nameInput.value.trim();

    if (!name) {
        errorDiv.textContent = 'Введите название!';
        errorDiv.style.display = 'block';
        return;
    }

    fetch('{% url "schedule:api_create_subject_template" %}', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
            'X-CSRFToken': '{{ csrf_token }}'
        },
        body: JSON.stringify({ name: name })
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            const select = document.getElementById('id_subject_template');
            const option = new Option(data.name, data.id, true, true);
            select.add(option);

            const modalEl = document.getElementById('addTemplateModal');
            const modal = bootstrap.Modal.getInstance(modalEl);
            modal.hide();

            nameInput.value = '';
            errorDiv.style.display = 'none';
        } else {
            errorDiv.textContent = data.error;
            errorDiv.style.display = 'block';
        }
    })
    .catch(err => {
        errorDiv.textContent = 'Ошибка сервера';
        errorDiv.style.display = 'block';
    });
}

document.addEventListener('DOMContentLoaded', function() {
    const creditsInput = document.getElementById('id_credits');
    const lecInput = document.getElementById('id_lecture_hours');
    const pracInput = document.getElementById('id_practice_hours');
    const labInput = document.getElementById('id_lab_hours');
    const srspInput = document.getElementById('id_control_hours');
    const srsInput = document.getElementById('id_independent_hours');

    const vLec = document.getElementById('view_l_slots');
    const vPrac = document.getElementById('view_p_slots');
    const vLab = document.getElementById('view_lab_slots');
    const vSrsp = document.getElementById('view_c_slots');

    function updateWeekly() {
        const weeks = 16;
        if(vLec) vLec.textContent = Math.ceil(((parseInt(lecInput.value)||0)/2)/weeks) + ' п/н';
        if(vPrac) vPrac.textContent = Math.ceil(((parseInt(pracInput.value)||0)/2)/weeks) + ' п/н';
        if(vLab) vLab.textContent = Math.ceil(((parseInt(labInput.value)||0)/2)/weeks) + ' п/н';
        if(vSrsp) vSrsp.textContent = Math.ceil(((parseInt(srspInput.value)||0)/2)/weeks) + ' п/н';
    }

    if (creditsInput) {
        creditsInput.addEventListener('input', function() {
            const credits = parseInt(this.value) || 0;
            if (credits <= 0) return;

            const totalHours = credits * 24;
            const srs = Math.floor(totalHours / 3);
            const auditory = totalHours - srs;

            let lec = 0, prac = 0, srsp = 0;

            if (auditory >= 64) {
                lec = 32; prac = 32; srsp = auditory - 64;
            } else if (auditory >= 48) {
                lec = 16; prac = 16; srsp = auditory - 32;
            } else if (auditory >= 32) {
                lec = 16; prac = 16; srsp = 0;
            } else {
                lec = auditory;
            }

            if(srsInput) srsInput.value = srs;
            if(lecInput) lecInput.value = lec;
            if(pracInput) pracInput.value = prac;
            if(labInput) labInput.value = 0;
            if(srspInput) srspInput.value = srsp;

            updateWeekly();
        });
    }

    [lecInput, pracInput, labInput, srspInput].forEach(el => {
        if(el) el.addEventListener('input', updateWeekly);
    });

    updateWeekly();
});
</script>
{% endblock %}
</file>

<file path="templates/schedule/schedule_view_unified.html">
{% extends 'base.html' %}
{% load static %}
{% load schedule_filters %}

{% block title %}Расписание{% endblock %}
{% block breadcrumbs %}
    <li class="breadcrumb-item active">Расписание занятий</li>
{% endblock %}
{% block content %}
<div class="row mt-4">
    {% if groups %}
    <div class="col-12">
        <div class="card mb-3">
            <div class="card-header bg-primary text-white">
                <i class="bi bi-people"></i> Выбор расписания
            </div>
            <div class="card-body">
                <form method="get">
                    <div class="row g-3">
                        {% if institutes %}
                        <div class="col-md-3">
                            <label class="form-label">Институт</label>
                            <select class="form-select" name="institute" onchange="this.form.submit()">
                                <option value="">-- Все институты --</option>
                                {% for inst in institutes %}
                                    <option value="{{ inst.id }}" {% if request.GET.institute == inst.id|stringformat:"s" %}selected{% endif %}>
                                        {{ inst.name }}
                                    </option>
                                {% endfor %}
                            </select>
                        </div>
                        {% endif %}
                        <div class="col-md-{% if institutes %}7{% else %}10{% endif %}">
                            <label class="form-label">Группа</label>
                            <select class="form-select" name="group" onchange="this.form.submit()">
                                <option value="">{% if user.role == 'TEACHER' %}-- Показать мое расписание (Все группы) --{% else %}Выбрать...{% endif %}</option>
                                {% for g in groups %}
                                    <option value="{{ g.id }}" {% if group and group.id == g.id %}selected{% endif %}>
                                        {{ g.name }} - {{ g.specialty|truncatewords:8 }} ({{ g.students.count }} чел.)
                                    </option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">&nbsp;</label>
                            <button type="submit" class="btn btn-primary w-100">
                                <i class="bi bi-arrow-clockwise"></i> Загрузить
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
    {% endif %}

    {% if group or is_teacher_view %}
    <div class="col-12">
        <div class="card">
            <div class="card-header bg-info text-white d-flex justify-content-between align-items-center">
                <span>
                    <i class="bi bi-calendar-week"></i> РАСПИСАНИЕ - {% if is_teacher_view %}МОИ ЗАНЯТИЯ{% else %}{{ group.name }}{% endif %}
                </span>
                <div>
                    {% if group %}
                    <a href="{% url 'schedule:export' %}?group={{ group.id }}"
                       class="btn btn-success btn-sm">
                        <i class="bi bi-download"></i> Экспорт DOCX
                    </a>
                    {% endif %}
                </div>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-bordered mb-0 schedule-table">
                        <thead class="table-light">
                            <tr>
                                <th style="width: 80px; vertical-align: middle; text-align: center;">
                                    <strong>ДЕНЬ НЕДЕЛИ<br>ЧАС</strong>
                                </th>
                                <th style="width: 90%;">Урок / {% if is_teacher_view %}Группа{% else %}Преподаватель{% endif %}</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for day_num, day_name in days %}
                                <tr class="table-secondary">
                                    <td colspan="2" class="text-center">
                                        <strong>{{ day_name }}</strong>
                                    </td>
                                </tr>

                                {% for time_slot in time_slots %}
                                    <tr>
                                        <td class="text-center align-middle time-cell">
                                            <strong style="font-size: 0.9rem;">
                                                {{ time_slot.start_time|time:"H" }}<sup>{{ time_slot.start_time|time:"i" }}</sup>-{{ time_slot.end_time|time:"H" }}<sup>{{ time_slot.end_time|time:"i" }}</sup>
                                            </strong>
                                        </td>

                                        {% with slot_list=schedule_data|get_slot:target_key|get_slot:day_num|get_slot:time_slot.id %}

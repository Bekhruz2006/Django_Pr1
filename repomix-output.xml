{% block content %}
<div class="chat-wrap">

    <div class="chat-sidebar">
        <div class="chat-sidebar-header">
            <i class="bi bi-chat-dots-fill"></i> Чаты
            <a href="{% url 'chat:start' %}"><i class="bi bi-plus-lg"></i> Новый</a>
        </div>
        <div class="rooms-list">
            {% for r in rooms %}
            {% with last=r.get_last_message %}
            <a href="{% url 'chat:room' r.id %}" class="room-item {% if r.id == room.id %}active{% endif %}">
                <div class="room-avatar">
                    {% for p in r.participants.all %}{% if p != user %}{{ p.first_name|first|upper }}{{ p.last_name|first|upper }}{% endif %}{% endfor %}
                </div>
                <div class="room-info">
                    <div class="room-name">{{ r }}</div>
                    {% if last %}
                    <div class="room-preview">
                        {% if last.file and not last.content %}📎 Файл{% else %}{{ last.content|truncatechars:30 }}{% endif %}
                    </div>
                    {% endif %}
                </div>
                <div class="room-meta">
                    {% if last %}<span class="room-time">{{ last.created_at|date:"H:i" }}</span>{% endif %}
                </div>
            </a>
            {% endwith %}
            {% endfor %}
        </div>
    </div>

    <div class="chat-main">
        <div class="chat-header">
            <div class="chat-header-avatar-wrap">
                <div class="chat-header-avatar">
                    {% for p in other_participants %}{{ p.first_name|first|upper }}{{ p.last_name|first|upper }}{% endfor %}
                </div>
            </div>
            <div class="chat-header-info">
                <div class="name">{% for p in other_participants %}{{ p.get_full_name }}{% if not forloop.last %}, {% endif %}{% endfor %}</div>
                <div class="subtitle">{% for p in other_participants %}{{ p.get_role_display }}{% endfor %}</div>
            </div>
        </div>

        <div class="messages-area" id="messagesArea">
            {% for message in messages %}
            <div class="msg-row {% if message.sender == user %}mine{% else %}theirs{% endif %}"
                 data-id="{{ message.id }}"
>

                {% if message.sender != user %}
                <div class="msg-avatar-small">
                    {{ message.sender.first_name|first|upper }}{{ message.sender.last_name|first|upper }}
                </div>
                {% endif %}

                <div class="msg-col">
                    <div class="msg-bubble {% if message.sender == user %}mine{% else %}theirs{% endif %}">
                        {% if message.file %}
                            {% if message.is_image %}
                            <img src="{{ message.file.url }}" class="file-msg-img"
                                 onclick="window.open('{{ message.file.url }}','_blank')">
                            {% else %}
                            <a href="{{ message.file.url }}" class="file-msg-doc" download>
                                <i class="{{ message.get_file_icon }}"></i>
                                {{ message.file_name|default:"Файл" }}
                            </a>
                            {% endif %}
                        {% endif %}
                        {% if message.content %}{{ message.content|linebreaksbr }}{% endif %}
                        {% if message.sender == user %}
                        <div class="msg-actions">
                            <button onclick="deleteMsg({{ message.id }}, this)" title="Удалить">
                                <i class="bi bi-trash"></i>
                            </button>
                        </div>
                        {% endif %}
                    </div>
                    <div class="msg-meta">
                        <span>{{ message.created_at|date:"H:i" }}</span>
                    </div>
                </div>
            </div>
            {% endfor %}

            <div id="msgBottom"></div>
            <div id="typingIndicator" class="typing-indicator">
                <div class="typing-dot"></div>
                <div class="typing-dot"></div>
                <div class="typing-dot"></div>
            </div>
        </div>

        <div class="chat-input-area">
            <div class="file-preview-bar" id="filePreviewBar">
                <i class="bi bi-paperclip"></i>
                <span class="file-name" id="filePreviewName"></span>
                <button onclick="clearFile()">×</button>
            </div>
            <div class="input-row">
                <button class="input-attach-btn" onclick="document.getElementById('fileInput').click()">
                    <i class="bi bi-paperclip"></i>
                </button>
                <input type="file" id="fileInput" style="display:none"
                       accept="image/*,.pdf,.doc,.docx,.xls,.xlsx,.txt">
                <textarea class="input-box" id="messageInput"
                          placeholder="Написать сообщение..." rows="1"></textarea>
                <button class="send-btn" id="sendBtn">
                    <i class="bi bi-send-fill"></i>
                </button>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block extra_js %}
<script>
const ROOM_ID  = {{ room.id }};
const MY_ID    = {{ user.id }};
const SEND_URL = '{% url "chat:send_message" room.id %}';
const POLL_URL = '{% url "chat:new_messages" room.id %}';
const CSRF     = '{{ csrf_token }}';

const area    = document.getElementById('messagesArea');
const input   = document.getElementById('messageInput');
const sendBtn = document.getElementById('sendBtn');
const fileInp = document.getElementById('fileInput');
const fileBar = document.getElementById('filePreviewBar');
const fileLbl = document.getElementById('filePreviewName');

let lastId = 0;
document.querySelectorAll('.msg-row[data-id]').forEach(el => {
    const n = +el.dataset.id;
    if (n > lastId) lastId = n;
});

const bottomAnchor = document.getElementById('msgBottom');

function scrollToBottom(smooth) {
    if (smooth) {
        bottomAnchor.scrollIntoView({ behavior: 'smooth', block: 'end' });
    } else {
        bottomAnchor.scrollIntoView(false);
    }
}

scrollToBottom(false);
requestAnimationFrame(() => scrollToBottom(false));
setTimeout(() => scrollToBottom(false), 100);
setTimeout(() => scrollToBottom(false), 400);

area.querySelectorAll('img').forEach(img => {
    if (!img.complete) img.addEventListener('load', () => scrollToBottom(false));
});

input.addEventListener('input', function () {
    this.style.height = 'auto';
    this.style.height = Math.min(this.scrollHeight, 120) + 'px';
});
input.addEventListener('keydown', e => {
    if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMessage(); }
});
sendBtn.addEventListener('click', sendMessage);

fileInp.addEventListener('change', function () {
    if (this.files[0]) { fileLbl.textContent = this.files[0].name; fileBar.classList.add('show'); }
});
function clearFile() { fileInp.value = ''; fileBar.classList.remove('show'); }

async function sendMessage() {
    const text = input.value.trim();
    const file = fileInp.files[0];
    if (!text && !file) return;
    sendBtn.disabled = true;
    const fd = new FormData();
    fd.append('csrfmiddlewaretoken', CSRF);
    if (text) fd.append('content', text);
    if (file) fd.append('file', file);
    input.value = ''; input.style.height = 'auto'; clearFile();
    try {
        const res  = await fetch(SEND_URL, { method: 'POST', body: fd });
        const data = await res.json();
        if (data.message) { appendMessage(data.message); lastId = data.message.id; scrollToBottom(true); }
    } catch (e) { console.error(e); }
    sendBtn.disabled = false;
    input.focus();
}

function buildBubble(msg) {
    const row = document.createElement('div');
    row.className = 'msg-row ' + (msg.is_mine ? 'mine' : 'theirs');
    row.dataset.id   = msg.id;

    const avatarHtml = !msg.is_mine
        ? `<div class="msg-avatar-small">${esc(msg.sender_initials)}</div>` : '';

    let fileHtml = '';
    if (msg.has_file) {
        if (msg.is_image) {
            fileHtml = `<img src="${msg.file_url}" class="file-msg-img" onclick="window.open('${msg.file_url}','_blank')">`;
        } else {
            fileHtml = `<a href="${msg.file_url}" class="file-msg-doc" download><i class="bi bi-file-earmark"></i>${esc(msg.file_name||'Файл')}</a>`;
        }
    }

    const delBtn = msg.is_mine
        ? `<div class="msg-actions"><button onclick="deleteMsg(${msg.id},this)" title="Удалить"><i class="bi bi-trash"></i></button></div>` : '';
    const content = msg.content ? esc(msg.content).replace(/\n/g,'<br>') : '';

    row.innerHTML = `
        ${avatarHtml}
        <div class="msg-col">
            <div class="msg-bubble ${msg.is_mine?'mine':'theirs'}">${fileHtml}${content}${delBtn}</div>
            <div class="msg-meta"><span>${msg.created_at}</span></div>
        </div>`;
    return row;
}

function appendMessage(msg) {
    if (document.querySelector(`.msg-row[data-id="${msg.id}"]`)) return;
    const typing = document.getElementById('typingIndicator');
    const el = buildBubble(msg);
    area.insertBefore(el, typing);
}

async function poll() {
    try {
        const res  = await fetch(`${POLL_URL}?last_id=${lastId}`);
        const data = await res.json();
        if (data.messages && data.messages.length) {
            const atBottom = area.scrollHeight - area.scrollTop - area.clientHeight < 80;
            data.messages.forEach(msg => { appendMessage(msg); if (msg.id > lastId) lastId = msg.id; });
            if (atBottom) scrollToBottom(true);
        }

    } catch (e) {}
}
setInterval(poll, 2500);

function observeForRead(el) {}
function markTickRead(id) {}

async function deleteMsg(id, btn) {
    if (!confirm('Удалить сообщение?')) return;
    try {
        const res = await fetch(`/chat/message/${id}/delete/`, {
            method: 'POST',
            headers: { 'X-CSRFToken': CSRF, 'X-Requested-With': 'XMLHttpRequest' }
        });
        if (res.ok) {
            const row = btn.closest('.msg-row');
            row.style.transition = 'opacity 0.25s';
            row.style.opacity = '0';
            setTimeout(() => row.remove(), 250);
        }
    } catch (e) {}
}

function esc(s) {
    if (!s) return '';
    return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}
</script>
{% endblock %}
</file>

<file path="templates/chat/start_chat.html">

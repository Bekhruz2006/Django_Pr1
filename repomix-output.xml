        <div class="progress mb-2" style="height:6px">
          <div class="progress-bar bg-success" style="width:{{ progress }}%"></div>
        </div>
        <small class="text-muted">{{ progress }}% {% trans "пройдено" %}</small>
        {% endwith %}
      </div>
      <div class="card-footer bg-transparent">
        <a href="{% url 'lms:course_detail' course.pk %}" class="btn btn-sm btn-outline-primary w-100">
          {% trans "Открыть" %}
        </a>
      </div>
    </div>
  </div>
  {% endfor %}
</div>
{% else %}
<div class="text-center text-muted py-5">
  <i class="bi bi-mortarboard" style="font-size:3rem"></i>
  <p class="mt-2">{% trans "Вы пока не записаны ни на один курс" %}</p>
  <a href="{% url 'lms:course_list' %}" class="btn btn-outline-primary">{% trans "Найти курс" %}</a>
</div>
{% endif %}

{% if manageable_courses %}
<hr>
<h5 class="mb-3">{% trans "Курсы под управлением" %}</h5>
<div class="list-group">
  {% for course in manageable_courses %}
  <a href="{% url 'lms:course_detail' course.pk %}" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
    <span>
      <strong>{{ course.short_name }}</strong>
      <span class="text-muted ms-2 small">{{ course.full_name }}</span>
    </span>
    <span class="badge bg-secondary">{{ course.enrolments.count }} {% trans "уч." %}</span>
  </a>
  {% endfor %}
</div>
{% endif %}
{% endblock %}
</file>


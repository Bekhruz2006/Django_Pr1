            if stats.total_absent > 15:
                risk_reasons.append(f"Слишком много прогулов: {stats.total_absent} (НБ)")
                risk_score += 2
            elif stats.total_absent > 8:
                risk_reasons.append(f"Частые пропуски: {stats.total_absent} (НБ)")
                risk_score += 1
                
            if risk_score >= 3:

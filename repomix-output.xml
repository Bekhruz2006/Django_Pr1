                                        <span class="text-danger small fw-bold">Не назначен</span>
                                        <br>
                                        <a href="{% url 'schedule:edit_subject' subject.id %}" class="btn btn-sm btn-outline-primary mt-1 py-0 px-2" style="font-size: 0.75rem;">Назначить</a>
                                    {% endif %}
                                </td>
                                <td>
                                    <small>
                                        {% for g in subject.groups.all|slice:":3" %}
                                            {{ g.name }}{% if not forloop.last %}, {% endif %}
                                        {% endfor %}
                                        {% if subject.groups.count > 3 %}...{% endif %}
                                    </small>
                                </td>
                                <td>
                                    {% if subject.syllabus_file %}
                                        <a href="{{ subject.syllabus_file.url }}" target="_blank" class="btn btn-sm btn-outline-info" title="Скачать">
                                            <i class="bi bi-file-earmark-arrow-down"></i>
                                        </a>
                                    {% else %}
                                        <span class="text-muted small">-</span>
                                    {% endif %}
                                </td>
                                <td class="text-end pe-4">
                                    <a href="{% url 'schedule:edit_subject' subject.id %}" class="btn btn-sm btn-light text-primary">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a href="{% url 'schedule:delete_subject' subject.id %}" class="btn btn-sm btn-light text-danger" onclick="return confirm('Удалить?')">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </td>
                            </tr>
                            {% empty %}
                            <tr><td colspan="6" class="text-center py-4 text-muted">Предметы не найдены. Сгенерируйте их из РУП.</td></tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
</file>

<file path="templates/schedule/manage_teacher_availability.html">
{% extends 'base.html' %}
{% block title %}График доступности преподавателей{% endblock %}

{% block content %}
<div class="row mt-4">
    <div class="col-12">
        <div class="card shadow border-primary">
            <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="bi bi-calendar-x"></i> Настройка выходных и "окон" преподавателей</h5>
                <a href="{% url 'schedule:constructor' %}" class="btn btn-sm btn-light text-primary fw-bold">К конструктору</a>
            </div>
            <div class="card-body bg-light">
                
                <div class="alert alert-info">
                    <i class="bi bi-info-circle-fill"></i> Выберите преподавателя и отметьте галочками те часы, в которые он <strong>НЕ МОЖЕТ</strong> вести занятия. Алгоритм авто-генерации (AI Timetabling) не будет ставить ему пары в это время.
                </div>

                <form method="get" class="mb-4 bg-white p-3 rounded border shadow-sm d-flex gap-3 align-items-end">
                    <div class="flex-grow-1">
                        <label class="form-label fw-bold text-muted small text-uppercase">Выберите преподавателя</label>
                        <select name="teacher_id" class="form-select border-primary" onchange="this.form.submit()">
                            <option value="">-- Выберите из списка --</option>
                            {% for t in teachers %}
                                <option value="{{ t.id }}" {% if selected_teacher and selected_teacher.id == t.id %}selected{% endif %}>
                                    {{ t.user.get_full_name }} ({{ t.department.name|default:"Без кафедры" }})
                                </option>
                            {% endfor %}
                        </select>
                    </div>
                </form>

                {% if selected_teacher %}
                    <form method="post">
                        {% csrf_token %}
                        <div class="card border-0 shadow-sm">
                            <div class="card-header bg-white py-3 border-bottom d-flex justify-content-between align-items-center">
                                <h6 class="mb-0 fw-bold text-dark">
                                    <i class="bi bi-person-badge text-success me-2"></i>
                                    График: {{ selected_teacher.user.get_full_name }}
                                </h6>
                                <div>
                                    <button type="button" class="btn btn-sm btn-outline-danger me-2" onclick="toggleAll(true)">Отметить всё (Выходной)</button>
                                    <button type="button" class="btn btn-sm btn-outline-success" onclick="toggleAll(false)">Снять всё (Доступен)</button>
                                </div>
                            </div>
                            <div class="card-body p-0">
                                <div class="table-responsive">
                                    <table class="table table-bordered table-hover align-middle mb-0 text-center">
                                        <thead class="table-light">
                                            <tr>
                                                <th style="width: 120px;">Время / День</th>
                                                {% for day_num, day_name in days %}
                                                    <th>{{ day_name }}</th>
                                                {% endfor %}
                                            </tr>
                                        </thead>
                                        <tbody>
                                            {% for ts in time_slots %}
                                                <tr>
                                                    <td class="fw-bold bg-light">
                                                        {{ ts.start_time|time:"H:i" }} - {{ ts.end_time|time:"H:i" }}
                                                        <br><small class="text-muted fw-normal">{{ ts.get_shift_display }}</small>
                                                    </td>
                                                    {% for day_num, day_name in days %}
                                                        {% with key=day_num|stringformat:"s"|add:"_"|add:ts.id|stringformat:"s" %}
                                                        <td class="p-0 position-relative" style="cursor: pointer;" onclick="toggleCheckbox('cb_{{ key }}')">
                                                            <div class="w-100 h-100 p-3 d-flex justify-content-center align-items-center">
                                                                <input type="checkbox" 
                                                                       class="form-check-input availability-cb" 
                                                                       style="transform: scale(1.5); cursor: pointer;"
                                                                       name="slot_{{ key }}" 
                                                                       id="cb_{{ key }}"
                                                                       value="1"
                                                                       {% if key in unavailable_set %}checked{% endif %}
                                                                       onclick="event.stopPropagation(); updateCellColor(this);">
                                                            </div>
                                                        </td>
                                                        {% endwith %}
                                                    {% endfor %}
                                                </tr>
                                            {% endfor %}
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                            <div class="card-footer bg-white text-end py-3">
                                <button type="submit" class="btn btn-primary btn-lg fw-bold px-5 shadow">
                                    <i class="bi bi-save"></i> Сохранить график
                                </button>
                            </div>
                        </div>
                    </form>
                {% else %}
                    <div class="text-center py-5 text-muted">
                        <i class="bi bi-person-lines-fill display-1 opacity-25"></i>
                        <h4 class="mt-3">Выберите преподавателя</h4>
                        <p>Чтобы настроить его график доступности.</p>
                    </div>
                {% endif %}

            </div>
        </div>
    </div>
</div>

<script>
    function toggleCheckbox(id) {
        const cb = document.getElementById(id);
        cb.checked = !cb.checked;
        updateCellColor(cb);
    }

    function updateCellColor(cb) {
        const td = cb.closest('td');
        if (cb.checked) {
            td.style.backgroundColor = 'rgba(239, 68, 68, 0.15)'; 
        } else {
            td.style.backgroundColor = 'transparent'; 
        }
    }

    function toggleAll(state) {
        document.querySelectorAll('.availability-cb').forEach(cb => {
            cb.checked = state;
            updateCellColor(cb);
        });
    }

    document.addEventListener('DOMContentLoaded', function() {
        document.querySelectorAll('.availability-cb').forEach(cb => {
            updateCellColor(cb);
        });
    });
</script>
{% endblock %}
</file>

<file path="templates/schedule/manage_time_slots.html">
{% extends 'base.html' %}
{% load i18n %}

{% block title %}{% trans "Управление звонками" %}{% endblock %}

{% block content %}
<div class="container-fluid py-4">
    <div class="row">
        <div class="col-lg-4 mb-4">
            <div class="card shadow-sm border-0 sticky-top" style="top: 80px;">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="bi bi-gear-fill"></i> {% trans "Генератор сетки" %}</h5>
                </div>
                <div class="card-body">
                    <form method="post">
                        {% csrf_token %}
                        
                        <div class="mb-3">
                            <label class="form-label fw-bold">{% trans "Уровень настройки" %}</label>
                            {{ form.institute }}
                            <div class="form-label fw-bold">Выберите "Глобальная настройка", чтобы задать время для всех, у кого нет своих настроек.</div>
                        </div>

                        <div class="row g-2 mb-3">
                            <div class="col-6">
                                <label class="form-label fw-bold">{% trans "Смена" %}</label>
                                {{ form.shift }}
                            </div>
                            <div class="col-6">
                                <label class="form-label fw-bold">{% trans "Начало 1-й пары" %}</label>
                                {{ form.start_time }}
                            </div>
                        </div>

                        <div class="card bg-light border-0 p-3 mb-3">
                            <h6 class="text-muted small text-uppercase fw-bold mb-2">Параметры времени (мин)</h6>
                            <div class="row g-2 align-items-end">
                                <div class="col-6">
                                    <label class="small">Урок</label>
                                    {{ form.lesson_duration }}
                                </div>
                                <div class="col-6">
                                    <label class="small">Перемена</label>
                                    {{ form.break_duration }}
                                </div>
                            </div>
                            <div class="mt-2">
                                <label class="small">Большая перемена после пары №</label>
                                <div class="input-group input-group-sm">
                                    {{ form.big_break_after }}
                                    <span class="form-check-label text-danger small">длит.</span>
                                    {{ form.big_break_duration }}
                                </div>
                            </div>
                        </div>
                        
                        <div class="mb-3">
                            <label class="form-label fw-bold">{% trans "Всего пар в смену" %}</label>
                            {{ form.pairs_count }}
                        </div>

                        <div class="form-check mb-3">
                            {{ form.delete_existing }}
                            <label class="form-check-label text-danger small" for="{{ form.delete_existing.id_for_label }}">
                                {% trans "Удалить старые звонки этой смены перед созданием" %}
                            </label>
                        </div>

                        <button type="submit" class="btn btn-success w-100 fw-bold shadow-sm">
                            <i class="bi bi-play-circle"></i> {% trans "Сгенерировать сетку" %}
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white border-bottom-0 pt-3">
                    <ul class="nav nav-tabs card-header-tabs" id="timeSlotsTabs" role="tablist">
                        <li class="nav-item">
                            <button class="nav-link active fw-bold" id="global-tab" data-bs-toggle="tab" data-bs-target="#global" type="button">
                                <i class="bi bi-play-circle"></i> Глобальные (ВУЗ)
                            </button>
                        </li>
                        <li class="nav-item">
                            <button class="nav-link fw-bold" id="institute-tab" data-bs-toggle="tab" data-bs-target="#institute" type="button">
                                <i class="bi bi-building"></i> По Институтам
                            </button>
                        </li>
                    </ul>
                </div>
                <div class="card-body bg-light">
                    <div class="tab-content" id="timeSlotsTabsContent">
                        
                        <div class="tab-pane fade show active" id="global" role="tabpanel">
                            {% if global_slots %}
                                <div class="table-responsive bg-white rounded shadow-sm">
                                    <table class="table table-hover align-middle mb-0">
                                        <thead class="table-dark">
                                            <tr>
                                                <th>Смена</th>
                                                <th class="text-center">№ Пары</th>
                                                <th class="text-center">Время</th>
                                                <th class="text-center">Длительность</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            {% regroup global_slots by get_shift_display as shift_list %}
                                            {% for shift in shift_list %}
                                                <tr class="table-secondary">
                                                    <td colspan="4" class="fw-bold ps-3">{{ shift.grouper }}</td>
                                                </tr>
                                                {% for slot in shift.list %}
                                                <tr>
                                                    <td></td>
                                                    <td class="text-center fw-bold">{{ slot.number }}</td>
                                                    <td class="text-center">
                                                        <span class="badge bg-light text-dark border fs-6">
                                                            {{ slot.start_time|time:"H:i" }} - {{ slot.end_time|time:"H:i" }}
                                                        </span>
                                                    </td>
                                                    <td class="text-center text-muted small">{{ slot.duration }} мин</td>
                                                </tr>
                                                {% endfor %}
                                            {% endfor %}
                                        </tbody>
                                    </table>
                                </div>
                            {% else %}
                                <div class="alert alert-warning text-center">
                                    <i class="bi bi-exclamation-circle"></i> Глобальная сетка звонков не настроена.
                                </div>
                            {% endif %}
                        </div>

                        <div class="tab-pane fade" id="institute" role="tabpanel">
                            {% if institute_slots %}
                                {% regroup institute_slots by institute as inst_list %}
                                {% for inst in inst_list %}
                                    <div class="card mb-3 border-0 shadow-sm">
                                        <div class="card-header bg-white fw-bold text-primary">
                                            <i class="bi bi-bank2 me-2"></i> {{ inst.grouper.name }}
                                        </div>
                                        <div class="table-responsive">
                                            <table class="table table-sm table-hover mb-0">
                                                <thead class="table-light">
                                                    <tr>
                                                        <th class="ps-3">Смена</th>
                                                        <th class="text-center">№</th>
                                                        <th class="text-center">Время</th>
                                                        <th></th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    {% for slot in inst.list %}
                                                    <tr>
                                                        <td class="ps-3">
                                                            {% if slot.shift == 'MORNING' %}<span class="badge bg-warning text-dark">Утро</span>
                                                            {% elif slot.shift == 'DAY' %}<span class="badge bg-info text-dark">День</span>
                                                            {% else %}<span class="badge bg-dark">Вечер</span>{% endif %}
                                                        </td>
                                                        <td class="text-center fw-bold">{{ slot.number }}</td>
                                                        <td class="text-center">{{ slot.start_time|time:"H:i" }} - {{ slot.end_time|time:"H:i" }}</td>
                                                        <td></td>
                                                    </tr>
                                                    {% endfor %}
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                {% endfor %}
                            {% else %}
                                <div class="alert alert-info text-center">
                                    <i class="bi bi-info-circle"></i> Индивидуальных настроек для институтов нет. Используется глобальная сетка.
                                </div>
                            {% endif %}
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
</file>


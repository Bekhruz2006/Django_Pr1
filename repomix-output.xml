<file path="templates/accounts/edit_user.html">
{% extends 'base.html' %}
{% load i18n %}

{% block title %}{% trans "Редактировать пользователя" %}{% endblock %}
{% block breadcrumbs %}
    <li class="breadcrumb-item"><a href="{% url 'accounts:user_management' %}">{% trans "Пользователи" %}</a></li>
    <li class="breadcrumb-item active">{% blocktrans %}Редактирование: {{ user_obj.username }}{% endblocktrans %}</li>
{% endblock %}
{% block content %}
<div class="row mt-4">
    <div class="col-lg-10 mx-auto">
        <div class="card">
            <div class="card-header">
                <i class="bi bi-pencil"></i> {% blocktrans %}Редактировать пользователя: {{ user_obj.get_full_name }}{% endblocktrans %}
            </div>
            <div class="card-body">
                <form method="post" enctype="multipart/form-data">
                    {% csrf_token %}
                    
                    <h5 class="mb-3">{% trans "Основная информация" %}</h5>
                    
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">{% trans "Имя" %}</label>
                            {{ user_form.first_name }}
                        </div>
                        
                        <div class="col-md-6 mb-3">
                            <label class="form-label">{% trans "Фамилия" %}</label>
                            {{ user_form.last_name }}
                        </div>
                    </div>
                    
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">{% trans "Телефон" %}</label>
                            {{ user_form.phone }}
                        </div>
                        
                        <div class="col-md-6 mb-3">
                            <label class="form-label">{% trans "Фото" %}</label>
                            {{ user_form.photo }}
                            {% if user_obj.photo %}
                                <br><small>{% trans "Текущее" %}: <a href="{{ user_obj.photo.url }}" target="_blank">{% trans "Посмотреть" %}</a></small>
                            {% endif %}
                        </div>
                    </div>
                    
                    <hr class="my-4">
                    <h5 class="mb-3 text-primary"><i class="bi bi-briefcase"></i> {% trans "Совместительство (Дополнительные роли)" %}</h5>
                    <div class="alert alert-light border small">
                        Отметьте галочками роли, которые должен выполнять этот пользователь. Для каждой выбранной роли ниже появится своя форма настроек.
                    </div>
                    <div class="row mb-4 bg-light p-3 rounded border mx-0">
                        <div class="col-md-4">
                            <div class="form-check form-switch">
                                {{ user_form.is_teacher }}
                                <label class="form-check-label fw-bold" for="{{ user_form.is_teacher.id_for_label }}">{{ user_form.is_teacher.label }}</label>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-check form-switch">
                                {{ user_form.is_head_of_dept }}
                                <label class="form-check-label fw-bold" for="{{ user_form.is_head_of_dept.id_for_label }}">{{ user_form.is_head_of_dept.label }}</label>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-check form-switch">
                                {{ user_form.is_dean }}
                                <label class="form-check-label fw-bold" for="{{ user_form.is_dean.id_for_label }}">{{ user_form.is_dean.label }}</label>
                            </div>
                        </div>
                    </div>

                    {% if student_form %}
                    <hr class="my-4">
                    <h5 class="mb-3 text-info"><i class="bi bi-mortarboard"></i> Профиль Студента</h5>
                    <div class="row">
                        {% for field in student_form %}
                            <div class="col-md-6 mb-3">
                                <label class="form-label">{{ field.label }}</label>
                                {{ field }}
                                {% if field.errors %}<div class="text-danger small">{{ field.errors }}</div>{% endif %}
                            </div>
                        {% endfor %}
                    </div>
                    {% endif %}

                    {% if teacher_form %}
                    <hr class="my-4">
                    <h5 class="mb-3 text-success"><i class="bi bi-person-video3"></i> Профиль Преподавателя</h5>
                    <div class="row">
                        {% for field in teacher_form %}
                            <div class="col-md-6 mb-3">
                                <label class="form-label">{{ field.label }}</label>
                                {{ field }}
                                {% if field.errors %}<div class="text-danger small">{{ field.errors }}</div>{% endif %}
                            </div>
                        {% endfor %}
                    </div>
                    {% endif %}

                    {% if head_form %}
                    <hr class="my-4">
                    <h5 class="mb-3 text-warning"><i class="bi bi-diagram-3"></i> Профиль Зав. кафедрой</h5>
                    <div class="row">
                        {% for field in head_form %}
                            <div class="col-md-6 mb-3">
                                <label class="form-label">{{ field.label }}</label>
                                {{ field }}
                                {% if field.errors %}<div class="text-danger small">{{ field.errors }}</div>{% endif %}
                            </div>
                        {% endfor %}
                    </div>
                    {% endif %}

                    {% if dean_form %}
                    <hr class="my-4">
                    <h5 class="mb-3 text-danger"><i class="bi bi-bank"></i> Профиль Декана</h5>
                    <div class="row">
                        {% for field in dean_form %}
                            <div class="col-md-6 mb-3">
                                <label class="form-label">{{ field.label }}</label>
                                {{ field }}
                                {% if field.errors %}<div class="text-danger small">{{ field.errors }}</div>{% endif %}
                            </div>
                        {% endfor %}
                    </div>
                    {% endif %}
                    
                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-circle"></i> {% trans "Сохранить изменения" %}
                        </button>
                        <a href="{% url 'accounts:user_management' %}" class="btn btn-secondary">
                            <i class="bi bi-x-circle"></i> {% trans "Отмена" %}
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    select, input[type="text"], input[type="date"], input[type="email"],
    input[type="number"], input[type="file"], textarea {
        width: 100%;
        padding: 0.5rem;
        border: 1px solid #ced4da;
        border-radius: 0.375rem;
    }
    textarea {
        min-height: 80px;
    }
</style>

<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

<script>
    $(document).ready(function() {
        $('.select2-multiple').select2({

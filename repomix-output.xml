                                    <select id="subj_ui_srsp" class="form-select border-warning subj-ui-calc">
                                        <option value="0">0 пар</option>
                                        <option value="0.5">0.5 (Раз в 2 нед.)</option>
                                        <option value="1">1 пара (Каждую)</option>
                                        <option value="1.5">1.5 пары</option>
                                        <option value="2">2 пары</option>
                                        <option value="3">3 пары</option>

def global_notifications(request):
    if not request.user.is_authenticated:
        return {}

    counts = {
        'orders': 0,
        'chat': 0,
        'news': 0,
        'total': 0
    }

    user = request.user
    counts['chat'] = ChatMessage.objects.filter(
        room__participants=user,

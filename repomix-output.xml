{% block content %}
<div class="row mt-4">
    <div class="col-12">
        <div class="card mb-3">
            <div class="card-header">
                <i class="bi bi-person-badge"></i> Моя успеваемость
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-2">

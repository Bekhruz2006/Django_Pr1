                    </div>
                    <div class="mb-3">
                        <label class="form-label">Тип колонки</label>
                        <select name="col_type" class="form-select">
                            <option value="WEEK" {% if col.col_type == 'WEEK' %}selected{% endif %}>Учебная неделя</option>
                            <option value="RATING" {% if col.col_type == 'RATING' %}selected{% endif %}>Рейтинг (Р1/Р2)</option>
                            <option value="EXAM" {% if col.col_type == 'EXAM' %}selected{% endif %}>Экзамен</option>
                        </select>
                    </div>
                    <div class="row">
                        <div class="col-6 mb-3">
                            <label class="form-label">Макс. балл</label>
                            <input type="number" step="0.1" name="max_score" class="form-control" value="{{ col.max_score|stringformat:'s' }}" required>
                        </div>
                        <div class="col-6 mb-3">
                            <label class="form-label">Порядок</label>
                            <input type="number" name="order" class="form-control" value="{{ col.order }}" required>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Отмена</button>
                    <button type="submit" class="btn btn-primary">Сохранить</button>
                </div>
            </form>
        </div>
    </div>
</div>
{% endfor %}
{% endblock %}
</file>


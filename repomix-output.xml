                        <div class="col-md-4 mb-3">
                            <label>{% trans "Дата" %}</label>
                            {{ form.date }}
                        </div>
                        <div class="col-md-4 mb-3">
                            <label>{% trans "Тип действия" %}</label>
                            {{ form.order_type }}
                        </div>

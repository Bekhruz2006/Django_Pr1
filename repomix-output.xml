<file path="templates/lms/section_grading.html">
{% extends "lms/base_lms.html" %}
{% block title %}Выставление баллов: {{ section.name }}{% endblock %}

{% block lms_content %}
<div class="card shadow-sm" style="max-width: 800px; margin: 0 auto;">
    <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="bi bi-journal-check"></i> Оценка: {{ section.name }}</h5>
        <a href="{% url 'lms:course_detail' course.id %}" class="btn btn-sm btn-light text-success">Назад к курсу</a>
    </div>
    <div class="card-body">
        <div class="alert alert-info">
            <i class="bi bi-info-circle"></i> Баллы, выставленные здесь, автоматически попадут в <strong>Сводную ведомость (Матрицу)</strong>. Максимальный балл: <strong>{{ column.max_score }}</strong>.
        </div>

        {% if is_auto_rating %}
            <div class="alert alert-warning py-3 shadow-sm border-warning">
                <h5 class="fw-bold text-dark"><i class="bi bi-robot text-warning"></i> Автоматический расчет</h5>
                <p class="mb-0">Баллы за этот раздел (Рейтинг/Экзамен) <strong>нельзя ввести вручную</strong>. Они автоматически подтягиваются из результатов <b>Тестирования (Quiz)</b>, которое студенты проходят в LMS.</p>
            </div>
        {% elif is_future and not is_admin %}
            <div class="alert alert-danger">
                <i class="bi bi-lock-fill"></i> <strong>Эта неделя еще не наступила!</strong> Выставление баллов за будущие недели заблокировано.
            </div>
        {% elif is_admin %}
            <div class="alert alert-warning py-2">
                <i class="bi bi-shield-lock-fill"></i> <strong>Режим Администратора:</strong> Ограничения по времени отключены.
            </div>
        {% endif %}

        <form method="post">
            {% csrf_token %}
            <table class="table table-hover table-bordered align-middle">
                <thead class="table-light">
                    <tr>
                        <th style="width: 50px;">№</th>
                        <th>Студент</th>
                        <th style="width: 150px;" class="text-center">Балл</th>
                    </tr>
                </thead>
                <tbody>
                    {% for item in student_data %}
                    <tr>
                        <td>{{ forloop.counter }}</td>
                        <td class="fw-bold">{{ item.student.user.get_full_name }}</td>
                        <td>
                            <input type="number" step="0.1" min="0" max="{{ column.max_score|stringformat:'s' }}" 
                                   name="score_{{ item.student.id }}"
                                   class="form-control text-center fw-bold text-primary"
                                   value="{{ item.score }}"
                                   {% if not can_edit %}disabled{% endif %}>
                        </td>
                    </tr>
                    {% empty %}
                    <tr><td colspan="3" class="text-center text-muted py-4">На курс не записано ни одного студента</td></tr>
                    {% endfor %}
                </tbody>
            </table>

            {% if can_edit and student_data %}
            <button type="submit" class="btn btn-success w-100 btn-lg mt-3">
                <i class="bi bi-save"></i> Сохранить баллы в ведомость
            </button>
            {% endif %}
        </form>
    </div>
</div>
{% endblock %}
</file>


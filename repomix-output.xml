    <script>
        document.getElementById('sidebarToggle')?.addEventListener('click', function(e) {
            e.stopPropagation();
            if (window.innerWidth > 768) {
                document.body.classList.toggle('sidebar-collapsed');
            } else {
                const sidebar = document.getElementById('sidebar');
                const isOpen = sidebar?.classList.toggle('show');
                document.body.classList.toggle('sidebar-open', isOpen);
            }
        });

        document.querySelectorAll('.sidebar-section-header').forEach(header => {
            header.addEventListener('click', function() {
                const target = document.getElementById(this.dataset.target);
                if (!target) return;
                target.classList.toggle('active');
                this.classList.toggle('active');
            });
        });

        const themeToggle = document.getElementById('themeToggle');
        const themeIcon = themeToggle.querySelector('i');
        if (localStorage.getItem('theme') === 'dark') {
            document.body.classList.add('dark-mode');
            themeIcon.className = 'bi bi-sun-fill';
        }
        themeToggle.addEventListener('click', function() {
            document.body.classList.toggle('dark-mode');
            const isDark = document.body.classList.contains('dark-mode');
            themeIcon.className = isDark ? 'bi bi-sun-fill' : 'bi bi-moon-fill';
            localStorage.setItem('theme', isDark ? 'dark' : 'light');
        });

        document.addEventListener('click', function(e) {
            const sidebar = document.getElementById('sidebar');
            const toggle = document.getElementById('sidebarToggle');

            if (document.body.classList.contains('sidebar-open')) {
                if ((sidebar && !sidebar.contains(e.target) && toggle && !toggle.contains(e.target)) || e.target === document.body) {
                    if (sidebar) sidebar.classList.remove('show');
                    document.body.classList.remove('sidebar-open');
                }
            }
        });

        window.addEventListener('pageshow', function(event) {
            document.body.classList.remove('sidebar-open', 'sb-sidenav-toggled');
            const sidebar = document.getElementById('sidebar');
            if (sidebar) sidebar.classList.remove('show');

            document.body.classList.remove('modal-open');
            document.body.style.overflow = '';
            document.body.style.paddingRight = '';
            document.querySelectorAll('.modal-backdrop').forEach(el => el.remove());
        });

        (function() {
            const badge = document.getElementById('chatFloatBadge');
            if (!badge) return;
            function updateChatBadge() {
                fetch('/chat/unread/')
                    .then(r => r.json())
                    .then(data => {
                        if (data.count > 0) {
                            badge.textContent = data.count > 99 ? '99+' : data.count;
                            badge.style.display = 'flex';
                        } else {
                            badge.style.display = 'none';
                        }
                    }).catch(() => {});
            }
            updateChatBadge();
            setInterval(updateChatBadge, 15000);
        })();
    </script>
    {% block extra_js %}{% endblock %}

<div class="modal fade" id="studentTrendModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title"><i class="bi bi-graph-up-arrow me-2"></i> Анализ динамики обучения</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-0">
                <div class="bg-light p-2 border-bottom d-flex justify-content-center gap-2">
                    <div class="btn-group btn-group-sm" role="group">
                        <input type="radio" class="btn-check trend-period" name="trendPeriod" id="tp_week" value="week">
                        <label class="btn btn-outline-secondary" for="tp_week">За неделю</label>
                        
                        <input type="radio" class="btn-check trend-period" name="trendPeriod" id="tp_month" value="month">
                        <label class="btn btn-outline-secondary" for="tp_month">За месяц</label>
                        
                        <input type="radio" class="btn-check trend-period" name="trendPeriod" id="tp_all" value="all" checked>
                        <label class="btn btn-outline-secondary" for="tp_all">За всё время</label>
                    </div>
                </div>
                <div id="studentTrendBody" class="p-4">
                </div>
            </div>
        </div>
    </div>
</div>

<script>
let currentTrendStudentId = null;
let currentTrendStudentName = '';

function showStudentTrend(studentId, studentName) {
    currentTrendStudentId = studentId;
    currentTrendStudentName = studentName;
    
    const modal = new bootstrap.Modal(document.getElementById('studentTrendModal'));
    modal.show();
    
    document.getElementById('tp_all').checked = true;
    fetchTrendData('all');
}

document.querySelectorAll('.trend-period').forEach(radio => {
    radio.addEventListener('change', function() {
        if(currentTrendStudentId) {
            fetchTrendData(this.value);
        }
    });
});

function fetchTrendData(period) {
    document.getElementById('studentTrendBody').innerHTML = '<div class="text-center py-4"><div class="spinner-border text-primary"></div><p class="mt-2 text-muted">Сбор данных и расчет алгоритма...</p></div>';

    fetch(`/journal/api/student-trend/${currentTrendStudentId}/?period=${period}`)
    .then(r => r.json())
    .then(data => {
        if(!data.success) {
            document.getElementById('studentTrendBody').innerHTML = `<div class="alert alert-danger">${data.error || 'Ошибка сервера'}</div>`;
            return;
        }
        if(!data.has_data) {
            document.getElementById('studentTrendBody').innerHTML = `<div class="alert alert-info text-center"><i class="bi bi-info-circle fs-1 d-block mb-2"></i>${data.message}</div>`;
            return;
        }

        const gpaSign = data.gpa_trend > 0 ? '+' : '';
        const attSign = data.att_trend > 0 ? '+' : '';
        const gpaColor = data.gpa_trend > 0 ? 'text-success' : (data.gpa_trend < 0 ? 'text-danger' : 'text-muted');
        const attColor = data.att_trend > 0 ? 'text-success' : (data.att_trend < 0 ? 'text-danger' : 'text-muted');

        document.getElementById('studentTrendBody').innerHTML = `
            <h5 class="fw-bold text-center mb-4">${currentTrendStudentName}</h5>
            <div class="row g-3 mb-4">
                <div class="col-6">
                    <div class="p-3 border rounded bg-light text-center h-100">
                        <small class="text-muted d-block text-uppercase fw-bold">GPA (Период)</small>
                        <h2 class="mb-0 text-dark">${data.gpa_current}</h2>
                        <span class="${gpaColor} small fw-bold">${gpaSign}${data.gpa_trend}% (динамика)</span>
                    </div>
                </div>
                <div class="col-6">
                    <div class="p-3 border rounded bg-light text-center h-100">
                        <small class="text-muted d-block text-uppercase fw-bold">Посещаемость</small>
                        <h2 class="mb-0 text-dark">${data.att_current}%</h2>
                        <span class="${attColor} small fw-bold">${attSign}${data.att_trend}% (динамика)</span>
                    </div>
                </div>
            </div>
            <div class="alert alert-${data.color} border-0 shadow-sm mb-0">
                <h6 class="fw-bold"><i class="bi bi-cpu"></i> Вывод алгоритма:</h6>
                <p class="mb-0 small">${data.prediction}</p>
            </div>
        `;
    }).catch(e => {
        document.getElementById('studentTrendBody').innerHTML = `<div class="alert alert-danger">Ошибка сети</div>`;
    });
}
</script>


</body>
</html>

<script>
document.getElementById('id_lecture_hours').readOnly = true;
document.getElementById('id_practice_hours').readOnly = true;
document.getElementById('id_lab_hours').readOnly = true;
document.getElementById('id_control_hours').readOnly = true;
document.getElementById('id_independent_work_hours').readOnly = true;

document.getElementById('id_lecture_hours').classList.add('bg-light');
document.getElementById('id_practice_hours').classList.add('bg-light');
document.getElementById('id_lab_hours').classList.add('bg-light');
document.getElementById('id_control_hours').classList.add('bg-light');
document.getElementById('id_independent_work_hours').classList.add('bg-light');

function calculateSubjHours() {
    const weeks = parseInt(document.getElementById('id_semester_weeks').value) || 16;
    const credits = parseFloat(document.getElementById('id_credits').value) || 0;
    
    const ctSelect = document.getElementById('id_credit_type');
    const hoursPerCredit = ctSelect && ctSelect.options[ctSelect.selectedIndex] ? 
                           parseFloat(ctSelect.options[ctSelect.selectedIndex].text.match(/\((\d+)ч\)/)?.[1] || 24) : 24;

    const lecPairs = parseFloat(document.getElementById('subj_ui_lec').value) || 0;
    const pracPairs = parseFloat(document.getElementById('subj_ui_prac').value) || 0;
    const labPairs = parseFloat(document.getElementById('subj_ui_lab').value) || 0;
    const srspPairs = parseFloat(document.getElementById('subj_ui_srsp').value) || 0;

    const lecHours = Math.round(lecPairs * 2 * weeks);
    const pracHours = Math.round(pracPairs * 2 * weeks);
    const labHours = Math.round(labPairs * 2 * weeks);
    const srspHours = Math.round(srspPairs * 2 * weeks);

    const totalAuditory = lecHours + pracHours + labHours + srspHours;
    const totalCreditHours = Math.round(credits * hoursPerCredit);
    
    let srsHours = totalCreditHours - totalAuditory;
    if (srsHours < 0) srsHours = 0; 

    document.getElementById('id_lecture_hours').value = lecHours;
    document.getElementById('id_practice_hours').value = pracHours;
    document.getElementById('id_lab_hours').value = labHours;
    document.getElementById('id_control_hours').value = srspHours;
    document.getElementById('id_independent_work_hours').value = srsHours;
    
    document.getElementById('subj_total_credits_badge').innerText = `${totalCreditHours} ч. всего`;
    
    const warningEl = document.getElementById('subj_hours_warning');
    if (totalAuditory > totalCreditHours && credits > 0) {
        warningEl.style.display = 'block';
        warningEl.innerHTML = `<i class="bi bi-exclamation-triangle-fill"></i> Внимание: Аудиторных часов (${totalAuditory}) больше, чем выделено кредитами (${totalCreditHours})!`;
    } else {
        warningEl.style.display = 'none';
    }
}

window.addEventListener('DOMContentLoaded', () => {
    const weeks = parseInt(document.getElementById('id_semester_weeks').value) || 16;
    const lec = parseInt(document.getElementById('id_lecture_hours').value) || 0;
    const prac = parseInt(document.getElementById('id_practice_hours').value) || 0;
    const lab = parseInt(document.getElementById('id_lab_hours').value) || 0;
    const srsp = parseInt(document.getElementById('id_control_hours').value) || 0;

    function setSelectSafe(selectId, pairs) {
        const select = document.getElementById(selectId);
        let exists = false;
        for(let i=0; i<select.options.length; i++) {
            if(parseFloat(select.options[i].value) === pairs) { exists = true; break; }
        }
        if(!exists && pairs > 0) { select.add(new Option(pairs + " пар", pairs)); }
        select.value = pairs.toString();
    }

    setSelectSafe('subj_ui_lec', lec / (2 * weeks));
    setSelectSafe('subj_ui_prac', prac / (2 * weeks));
    setSelectSafe('subj_ui_lab', lab / (2 * weeks));
    setSelectSafe('subj_ui_srsp', srsp / (2 * weeks));

    calculateSubjHours();
});

document.querySelectorAll('.subj-ui-calc').forEach(el => {
    el.addEventListener('input', calculateSubjHours);
    el.addEventListener('change', calculateSubjHours);
});
document.getElementById('id_credits').addEventListener('input', calculateSubjHours);
document.getElementById('id_credit_type').addEventListener('change', calculateSubjHours);
document.getElementById('id_semester_weeks').addEventListener('input', calculateSubjHours);
</script>
{% endblock %}
</file>


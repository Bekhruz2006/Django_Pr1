        )

        self.plan, _ = AcademicPlan.objects.get_or_create(specialty=self.spec_cs, admission_year=2024, defaults={'is_active': True})

        disciplines_data =[
            ('Программирование на Python', 5, 32, 32, 0, self.teachers[0]),

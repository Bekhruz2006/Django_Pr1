{% block content %}
<div class="chats-page">
    <div class="chats-header">
        <div class="chats-title"><i class="bi bi-chat-dots me-2"></i>Сообщения</div>
        <a href="{% url 'chat:start' %}" class="btn btn-primary">
            <i class="bi bi-pencil-square me-1"></i> Новый чат
        </a>
    </div>

    {% if rooms %}
        {% for room in rooms %}
        <a href="{% url 'chat:room' room.id %}" class="chat-card {% if room.unread > 0 %}unread{% endif %}">
            <div class="chat-avatar">
                {% if room.other %}
                    {{ room.other.first_name|first|upper }}{{ room.other.last_name|first|upper }}

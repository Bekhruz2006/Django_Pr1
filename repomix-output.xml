                    <div class="mb-3">
                        <label>{% trans "Заголовок приказа" %}</label>
                        {{ form.title }}
                    </div>
                    <div class="mb-3">
                        <label>{% trans "Статус" %}</label>
                        {{ form.status }}
                    </div>
                    <div class="mb-3">
                        <label>{% trans "Причина / Основание" %}</label>
                        {{ form.reason }}
                    </div>
                    <div class="mb-3">
                        <label>{% trans "Скан файла (опционально)" %}</label>
                        {{ form.file }}
                    </div>
                    <button type="submit" class="btn btn-danger w-100">{% trans "Издать приказ" %}</button>
                </form>

                <h6 class="border-bottom pb-2">{% trans "История приказов" %}</h6>
                <div class="table-responsive">
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th>{% trans "№" %}</th>
                                <th>{% trans "Дата" %}</th>
                                <th>{% trans "Тип" %}</th>
                                <th>{% trans "Файл" %}</th>
                            </tr>
                        </thead>
                        <tbody>

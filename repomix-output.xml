<file path="templates/schedule/plans/create_plan.html">
{% extends 'base.html' %}

{% block title %}Создать учебный план (РУП){% endblock %}

{% block breadcrumbs %}
    <li class="breadcrumb-item"><a href="{% url 'schedule:manage_plans' %}">Учебные планы</a></li>
    <li class="breadcrumb-item active">Создание</li>
{% endblock %}

{% block content %}
<div class="row mt-4">
    <div class="col-lg-6 mx-auto">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-primary text-white py-3">
                <h5 class="mb-0"><i class="bi bi-journal-plus"></i> Создание учебного плана (РУП)</h5>
            </div>
            <div class="card-body p-4">
                <form method="post" id="createPlanForm">
                    {% csrf_token %}
                    
                    {% if form.non_field_errors %}
                        <div class="alert alert-danger">{{ form.non_field_errors }}</div>
                    {% endif %}

                    <div class="mb-4">
                        <label class="form-label fw-bold text-dark">Специальность *</label>
                        {{ form.specialty }}
                        <div class="form-text text-muted">Выберите специальность, для которой создается план.</div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-4">
                            <label class="form-label fw-bold text-dark">Год набора (поступления) *</label>
                            {{ form.admission_year }}
                        </div>

                        <div class="col-md-6 mb-4 d-flex align-items-center">
                            <div class="form-check form-switch mt-3">
                                {{ form.is_active }}
                                <label class="form-check-label" for="{{ form.is_active.id_for_label }}">
                                    Сделать активным сразу
                                </label>
                            </div>
                        </div>
                    </div>

                    <hr class="my-3 text-muted">

                    <div class="mb-4 bg-light p-3 rounded border">
                        <label class="form-label fw-bold text-primary">
                            <i class="bi bi-people-fill"></i> Индивидуальный план для группы (Опционально)
                        </label>
                        {{ form.group }}
                        <div class="form-text mt-2">
                            Выберите группу <strong>ТОЛЬКО</strong> если этот план отличается от общего плана специальности. 
                            <br>Оставьте "Общий план", если он подходит для всех.
                        </div>
                    </div>

                    <div class="d-flex gap-2 justify-content-end">
                        <a href="{% url 'schedule:manage_plans' %}" class="btn btn-light border">Отмена</a>
                        <button type="submit" class="btn btn-success px-4 fw-bold">
                            <i class="bi bi-check-lg"></i> Создать план
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const specialtySelect = document.getElementById('id_specialty');
    const groupSelect = document.getElementById('id_group');
    
    
    const allGroups = [
        {% for group in all_groups %}
        {
            id: "{{ group.id }}",
            name: "{{ group.name }}",
            specialty_id: "{{ group.specialty.id }}"
        },
        {% endfor %}
    ];

    function filterGroups() {
        const selectedSpecId = specialtySelect.value;
        const currentGroupValue = groupSelect.value;
        
        groupSelect.innerHTML = '<option value="">-- Общий план для всей специальности --</option>';
        
        const filteredGroups = allGroups.filter(g => g.specialty_id == selectedSpecId);
        
        filteredGroups.forEach(g => {
            const option = new Option(g.name, g.id);
            if (g.id === currentGroupValue) option.selected = true;
            groupSelect.add(option);
        });
        
        if (filteredGroups.length === 0 && selectedSpecId) {
             const option = new Option("(Нет групп на этой специальности)", "");
             option.disabled = true;
             groupSelect.add(option);
        }
    }

    specialtySelect.addEventListener('change', filterGroups);
    
    filterGroups();
});
</script>
{% endblock %}
</file>

<file path="templates/schedule/plans/generate_preview.html">
{% extends 'base.html' %}
{% block title %}Предпросмотр генерации нагрузки{% endblock %}

{% block content %}
<div class="row mt-4">
    <div class="col-lg-12 mx-auto">
        <div class="card shadow border-0">
            <div class="card-header bg-primary text-white py-3 d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="bi bi-list-check"></i> Предпросмотр создаваемых дисциплин</h5>
                {% if suggestions %}
                <button type="button" class="btn btn-warning btn-sm fw-bold text-dark shadow-sm" data-bs-toggle="modal" data-bs-target="#aiConfigModal">
                    <i class="bi bi-robot"></i> Распределить с помощью ИИ
                </button>
                {% endif %}
            </div>
            <div class="card-body">
                {% if diagnostics %}
                    <div class="alert alert-warning mb-4">
                        <h6 class="fw-bold"><i class="bi bi-exclamation-triangle"></i> Пропущенные группы (требуют внимания):</h6>
                        <ul class="mb-0 small">
                            {% for d in diagnostics %}<li>{{ d }}</li>{% endfor %}
                        </ul>
                    </div>
                {% endif %}

                <form method="post" id="generationForm">
                    {% csrf_token %}
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th><input type="checkbox" id="selectAll" class="form-check-input" checked></th>
                                    <th>Дисциплина</th>
                                    <th>Часы (Л/П/Лаб/СРСП)</th>
                                    <th>Группы</th>
                                    <th>Преподаватель (ИИ или Вручную)</th>
                                    <th>Объединить в поток?</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for item in suggestions %}
                                <tr data-key="{{ item.key }}" data-subject-name="{{ item.template.name }}">
                                    <td>
                                        <input type="checkbox" name="selected_items" value="{{ item.key }}" class="form-check-input item-check" checked>
                                    </td>
                                    <td class="fw-bold text-primary">{{ item.template.name }}</td>
                                    <td><span class="badge bg-light text-dark border">{{ item.hours }}</span></td>
                                    <td>
                                        {% for g in item.groups %}
                                            <span class="badge bg-secondary">{{ g.name }}</span>
                                        {% endfor %}
                                    </td>
                                    <td>
                                        <select name="teacher_{{ item.key }}" id="teacher_select_{{ item.key }}" class="form-select form-select-sm border-info ai-target-select">
                                            <option value="">-- Не назначен --</option>
                                            {% for t in teachers %}
                                                <option value="{{ t.id }}">{{ t.user.get_full_name }} ({{ t.department.name|truncatechars:15 }})</option>
                                            {% endfor %}
                                        </select>
                                        <div id="ai_reason_{{ item.key }}" class="small text-success mt-1 fw-bold" style="display: none; font-size: 0.75rem;"></div>
                                    </td>
                                    <td>
                                        {% if item.groups|length > 1 %}
                                            <div class="form-check form-switch">
                                                <input class="form-check-input" type="checkbox" name="make_stream_{{ item.key }}">
                                                <label class="form-check-label small text-muted">Сделать лекцию общей</label>
                                            </div>
                                        {% else %}
                                            <span class="text-muted small">Одна группа</span>
                                        {% endif %}
                                    </td>
                                </tr>
                                {% empty %}
                                <tr><td colspan="6" class="text-center py-5 text-muted">Все дисциплины для активных семестров уже сгенерированы!</td></tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                    {% if suggestions %}
                    <div class="mt-4">
                        <button type="submit" class="btn btn-success px-4"><i class="bi bi-magic"></i> Сгенерировать выбранные</button>
                        <a href="{% url 'schedule:manage_plans' %}" class="btn btn-light">Отмена</a>
                    </div>
                    {% endif %}
                </form>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="aiConfigModal" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-warning text-dark">
                <h5 class="modal-title fw-bold"><i class="bi bi-robot"></i> Настройка ИИ-распределения</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body" id="aiModalBody">
                <div class="alert alert-info small">
                    <i class="bi bi-info-circle"></i> Система проанализирует выбранные предметы и подберет преподавателей на основе их компетенций, кафедры и текущей нагрузки.
                </div>

                <div class="mb-4 bg-white p-3 rounded border">
                    <label class="form-label fw-bold text-dark"><i class="bi bi-cpu"></i> Метод распределения:</label>

                    <div class="form-check mb-2">
                        <input class="form-check-input" type="radio" name="assignMethod" id="methodAlgo" value="algo" checked>
                        <label class="form-check-label" for="methodAlgo">
                            <span class="fw-bold text-success">Алгоритмический (Умный балансировщик)</span><br>
                            <small class="text-muted">Мгновенно. Ищет совпадения по компетенциям (тегам), привязке к кафедре и следит, чтобы у преподавателей была равномерная нагрузка.</small>
                        </label>
                    </div>

                    <div class="form-check">
                        <input class="form-check-input" type="radio" name="assignMethod" id="methodLLM" value="llm">
                        <label class="form-check-label" for="methodLLM">
                            <span class="fw-bold text-primary">Нейросеть (LLM Ollama)</span><br>
                            <small class="text-muted">Глубокий семантический анализ биографии и научных интересов. (Работает медленнее, требует запущенного сервера Ollama).</small>
                        </label>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Участвующие преподаватели:</label>
                    <div class="border rounded p-3 bg-light" style="max-height: 250px; overflow-y: auto;">
                        <div class="form-check mb-2 border-bottom pb-2">
                            <input class="form-check-input" type="checkbox" id="selectAllTeachers" checked onchange="toggleAllTeachers(this)">
                            <label class="form-check-label fw-bold text-primary" for="selectAllTeachers">Выбрать всех</label>
                        </div>
                        {% for t in teachers %}
                        <div class="form-check">
                            <input class="form-check-input ai-teacher-cb" type="checkbox" value="{{ t.id }}" id="t_cb_{{ t.id }}" checked>
                            <label class="form-check-label" for="t_cb_{{ t.id }}">
                                {{ t.user.get_full_name }}
                                <small class="text-muted">({{ t.department.name }})</small>
                                {% if t.competencies.exists %}
                                    <br><small class="text-success" style="font-size: 0.7rem;">Навыки: {% for c in t.competencies.all %}{{ c.name }}{% if not forloop.last %}, {% endif %}{% endfor %}</small>
                                {% endif %}
                            </label>
                        </div>
                        {% endfor %}
                    </div>
                </div>
            </div>

            <div class="modal-body text-center" id="aiLoadingBody" style="display: none; padding: 60px 20px;">
                <div class="spinner-border text-warning" style="width: 4rem; height: 4rem; border-width: 0.4rem;" role="status"></div>
                <h4 class="mt-4 fw-bold">ИИ анализирует данные...</h4>
                <p class="text-muted mb-4">Пожалуйста, не закрывайте страницу. Процесс может занять от 2 до 15 минут в зависимости от выбранной модели.</p>
                <div class="progress" style="height: 10px;">
                    <div class="progress-bar progress-bar-striped progress-bar-animated bg-warning w-100"></div>
                </div>
            </div>

            <div class="modal-footer bg-light" id="aiModalFooter">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Отмена</button>
                <button type="button" class="btn btn-warning fw-bold" onclick="startAIAssignment()">
                    <i class="bi bi-play-fill"></i> Запустить ИИ
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    document.getElementById('selectAll')?.addEventListener('change', function() {
        document.querySelectorAll('.item-check').forEach(cb => cb.checked = this.checked);
    });

    function toggleAllTeachers(master) {
        document.querySelectorAll('.ai-teacher-cb').forEach(cb => cb.checked = master.checked);
    }

    function getCookie(name) {
        let cookieValue = null;
        if (document.cookie && document.cookie !== '') {
            const cookies = document.cookie.split(';');
            for (let i = 0; i < cookies.length; i++) {
                const cookie = cookies[i].trim();
                if (cookie.substring(0, name.length + 1) === (name + '=')) {
                    cookieValue = decodeURIComponent(cookie.substring(name.length + 1));
                    break;
                }
            }
        }
        return cookieValue;
    }

    function startAIAssignment() {
        const subjects = [];
        document.querySelectorAll('tr[data-key]').forEach(tr => {
            if (tr.querySelector('.item-check').checked) {
                subjects.push({
                    key: tr.dataset.key,
                    name: tr.dataset.subjectName
                });
            }
        });

        if (subjects.length === 0) {
            alert('Сначала выберите хотя бы один предмет в таблице!');
            return;
        }

        const teacherIds =[];
        document.querySelectorAll('.ai-teacher-cb:checked').forEach(cb => {
            teacherIds.push(parseInt(cb.value));
        });

        if (teacherIds.length === 0) {
            alert('Выберите хотя бы одного преподавателя для распределения!');
            return;
        }

        const assignMethod = document.querySelector('input[name="assignMethod"]:checked').value;
        const modelName = 'gemma3:4b';

        document.getElementById('aiModalBody').style.display = 'none';
        document.getElementById('aiLoadingBody').style.display = 'block';
        document.querySelectorAll('#aiModalFooter button').forEach(btn => btn.disabled = true);

        fetch("{% url 'schedule:api_ai_assign_teachers' %}", {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'X-CSRFToken': getCookie('csrftoken')
            },
            body: JSON.stringify({
                subjects: subjects,
                teacher_ids: teacherIds,
                model_name: modelName,
                method: assignMethod
            })
        })
        .then(response => response.json())
        .then(data => {
            document.querySelectorAll('#aiModalFooter button').forEach(btn => btn.disabled = false);

            if (data.success) {
                let successCount = 0;
                let notFoundCount = 0;

                data.assignments.forEach(assign => {
                    const select = document.getElementById(`teacher_select_${assign.key}`);
                    const reasonDiv = document.getElementById(`ai_reason_${assign.key}`);

                    if (select) {
                        if (assign.teacher_id) {
                            select.value = assign.teacher_id;
                            select.classList.add('bg-success', 'bg-opacity-10');

                            if (reasonDiv && assign.reason) {
                                reasonDiv.innerText = `💡 ${assign.reason}`;
                                reasonDiv.style.display = 'block';
                                reasonDiv.classList.remove('text-danger');
                                reasonDiv.classList.add('text-success');
                            }
                            successCount++;
                        } else {
                            select.value = "";
                            select.classList.add('bg-warning', 'bg-opacity-10');
                            if (reasonDiv) {
                                reasonDiv.innerText = `⚠️ ${assign.reason || 'Подходящий преподаватель не найден'}`;
                                reasonDiv.classList.remove('text-success');
                                reasonDiv.classList.add('text-danger');
                                reasonDiv.style.display = 'block';
                            }
                            notFoundCount++;
                        }
                    }
                });

                const modal = bootstrap.Modal.getInstance(document.getElementById('aiConfigModal'));
                modal.hide();

                alert(`Распределение завершено!\n✅ Назначено: ${successCount}\n❌ Не найдено: ${notFoundCount}`);
            } else {
                alert('Ошибка: ' + data.error);
                document.getElementById('aiModalBody').style.display = 'block';
                document.getElementById('aiLoadingBody').style.display = 'none';
            }
        })
        .catch(error => {
            console.error('Fetch error:', error);
            alert('Ошибка соединения с сервером. Попробуйте позже.');
            document.getElementById('aiModalBody').style.display = 'block';
            document.getElementById('aiLoadingBody').style.display = 'none';
            document.querySelectorAll('#aiModalFooter button').forEach(btn => btn.disabled = false);
        });
    }
</script>
{% endblock %}
</file>

<file path="templates/schedule/plans/manage_plans.html">
{% extends 'base.html' %}
{% block breadcrumbs %}
    <li class="breadcrumb-item active">Учебные планы</li>
{% endblock %}

{% block content %}
<div class="row mt-4">
    <div class="col-12">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h3>📂 Рабочие учебные планы (РУП)</h3>
            <div>
                <a href="{% url 'schedule:generate_subjects' %}" class="btn btn-warning me-2 text-dark">
                    <i class="bi bi-magic"></i> Генерация нагрузки
                </a>
                <a href="{% url 'schedule:create_plan' %}" class="btn btn-success">
                    <i class="bi bi-plus-lg"></i> Создать план
                </a>
            </div>
        </div>

        <div class="list-group shadow-sm">
            {% for plan in plans %}
                <a href="{% url 'schedule:plan_detail' plan.id %}" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center p-3">
                    <div>
                        <h5 class="mb-1 fw-bold text-primary">{{ plan.specialty.name }}</h5>
                        <div class="text-muted small">
                            <i class="bi bi-calendar-event"></i> Год набора: {{ plan.admission_year }} |
                            <i class="bi bi-code-slash"></i> Код: {{ plan.specialty.code }}
                        </div>
                    </div>
                    <div class="text-end d-flex align-items-center gap-2">
                        <span class="badge bg-primary rounded-pill">{{ plan.disciplines.count }} дисциплин</span>
                        {% if plan.is_active %}
                            <span class="badge bg-success">Актуален</span>
                        {% else %}
                            <span class="badge bg-secondary">Архив</span>
                        {% endif %}
                        <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#copyPlanModal{{ plan.id }}" title="Копировать план">
                            <i class="bi bi-files"></i>
                        </button>
                    </div>
                </a>

                <div class="modal fade" id="copyPlanModal{{ plan.id }}" tabindex="-1">
                    <div class="modal-dialog">
                        <div class="modal-content">
                            <form action="{% url 'schedule:copy_plan' plan.id %}" method="post">
                                {% csrf_token %}
                                <div class="modal-header">
                                    <h5 class="modal-title">Копировать РУП {{ plan.admission_year }}</h5>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                </div>
                                <div class="modal-body">
                                    <p>Создать копию плана специальности <strong>{{ plan.specialty.name }}</strong>.</p>
                                    <label class="form-label">Новый год набора:</label>
                                    <input type="number" name="new_year" class="form-control" value="{{ plan.admission_year|add:1 }}" required>
                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Отмена</button>
                                    <button type="submit" class="btn btn-primary">Копировать</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            {% empty %}
                <div class="text-center py-5 text-muted">
                    <i class="bi bi-folder2-open display-4"></i>
                    <p class="mt-3">Планов пока нет. Создайте первый РУП.</p>
                </div>
            {% endfor %}
        </div>
    </div>
</div>
{% endblock %}
</file>

<file path="templates/schedule/plans/plan_detail.html">
{% extends 'base.html' %}

{% block title %}РУП: {{ plan.specialty.name }}{% endblock %}

{% block breadcrumbs %}
    <li class="breadcrumb-item"><a href="{% url 'schedule:manage_plans' %}">Учебные планы</a></li>
    <li class="breadcrumb-item active">{{ plan.specialty.code }}</li>
{% endblock %}

{% block content %}
<style>
    .semester-nav .nav-link {
        color: #495057 !important;
        background-color: #e9ecef !important;
        border: 1px solid #dee2e6 !important;
        margin-right: 5px;
        font-weight: 600;
    }

    .semester-nav .nav-link:hover {
        background-color: #dee2e6 !important;
        color: #000 !important;
    }

    .semester-nav .nav-link.active {
        background-color: #0d6efd !important;
        color: #ffffff !important;
        border-color: #0d6efd !important;
        box-shadow: 0 4px 6px rgba(13, 110, 253, 0.3);
    }
    @keyframes pulse-green {
        0% { box-shadow: 0 0 0 0 rgba(25, 135, 84, 0.7); }
        70% { box-shadow: 0 0 0 6px rgba(25, 135, 84, 0); }
        100% { box-shadow: 0 0 0 0 rgba(25, 135, 84, 0); }
    }
    .animate-pulse {
        animation: pulse-green 2s infinite;
    }
</style>

<div class="row mt-4">
    <div class="col-12 mb-3">
        <div class="card shadow-sm border-0">
            <div class="card-body d-flex justify-content-between align-items-center bg-white rounded">
                <div>
                    <div class="d-flex align-items-center gap-3">
                        <h4 class="mb-0 text-dark fw-bold">
                            {% if plan.specialty %}
                                {{ plan.specialty.name }}
                            {% else %}
                                Индивидуальный план группы: {{ plan.group.name }}
                            {% endif %}
                        </h4>
                        {% if plan.is_active %}
                            <span class="badge bg-success shadow-sm">АКТИВНЫЙ ПЛАН</span>
                        {% else %}
                            <span class="badge bg-secondary opacity-50">АРХИВНЫЙ</span>
                            <a href="{% url 'schedule:activate_plan' plan.id %}" class="btn btn-sm btn-outline-success ms-2">
                                <i class="bi bi-play-circle"></i> Сделать активным
                            </a>
                        {% endif %}
                    </div>
                    <p class="mb-0 text-secondary mt-1">
                        {% if plan.specialty %}
                            Код: <strong>{{ plan.specialty.code }}</strong> | 
                        {% elif plan.group and plan.group.specialty %}
                            Код спец.: <strong>{{ plan.group.specialty.code }}</strong> | 
                        {% endif %}
                        Год набора: <strong>{{ plan.admission_year }}</strong>
                    </p>
                </div>
                <div class="d-flex gap-2">
                    <a href="{% url 'schedule:generate_subjects' %}" class="btn btn-warning text-dark shadow-sm">
                        <i class="bi bi-magic"></i> Создать нагрузку
                    </a>
                    <a href="{% url 'schedule:delete_plan' plan.id %}" class="btn btn-outline-danger shadow-sm" onclick="return confirm('Вы уверены? Это удалит ВЕСЬ план и все дисциплины в нем!')">
                        <i class="bi bi-trash"></i> Удалить план
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="col-12 mb-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-2">
                <ul class="nav nav-pills semester-nav" id="semesterTabs">
                    {% for i in semesters_range %}
                    <li class="nav-item">
                        <a class="nav-link {% if i == current_sem_num %}active{% endif %}"
                           href="?semester={{ i }}">
                           {{ i }} Семестр
                        </a>
                    </li>
                    {% endfor %}
                </ul>
            </div>
        </div>
    </div>

    <div class="col-12 mb-4">
        <div class="card border-0 shadow-sm bg-light">
            <div class="card-body py-3 d-flex justify-content-between align-items-center flex-wrap gap-3">
                <div>
                    <h6 class="fw-bold mb-1 text-primary">
                        <i class="bi bi-calendar-check"></i> Настройка периода для {{ target_course }} курса
                    </h6>
                    <small class="text-muted">
                        Выберите, какой семестр (из созданных в настройках) сейчас идет у студентов этого курса.
                    </small>
                </div>

                <div class="d-flex align-items-center bg-white p-2 rounded border">
                    <form action="{% url 'schedule:set_active_semester_manual' %}" method="post" class="d-flex align-items-center gap-2">
                        {% csrf_token %}

                        <div class="input-group input-group-sm">
                            <span class="bi bi-check2-circle">Текущий </span>
                            <select name="semester_id" class="form-select border-start-0 ps-1 fw-bold" style="min-width: 250px;">
                                <option value="" disabled {% if not active_semester %}selected{% endif %}>-- Не выбран --</option>
                                {% for sem in available_semesters %}
                                    <option value="{{ sem.id }}" {% if sem.is_active %}selected{% endif %}>
                                        {{ sem.academic_year }} | {{ sem.name }} ({{ sem.get_shift_display }})
                                        {% if sem.is_active %} ✅{% endif %}
                                    </option>
                                {% endfor %}
                            </select>
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check2-circle"></i> Активировать
                            </button>
                        </div>
                    </form>

                    <div class="vr mx-2"></div>

                    <a href="{% url 'schedule:add_semester' %}" class="btn btn-sm btn-outline-secondary" title="Создать новый, если нет в списке">
                        <i class="bi bi-plus-lg"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow-sm border-0 sticky-top" style="top: 80px;">
            <div class="card-header bg-primary text-white">
                <h6 class="mb-0"><i class="bi bi-plus-circle"></i> Добавить в {{ current_sem_num }} семестр</h6>
            </div>
            <div class="card-body p-3">
                <form method="post">
                    {% csrf_token %}
                    <input type="hidden" name="add_discipline" value="1">
                    {{ form.semester_number }}

                    {% if form.errors %}
                        <div class="alert alert-danger p-2 small mb-3">
                            <strong>Ошибка!</strong> Проверьте поля. {{ form.errors }}
                        </div>
                    {% endif %}

                    <div class="mb-3">
                        <label class="form-label small fw-bold text-muted text-uppercase">Дисциплина</label>
                        <div class="input-group">
                            {{ form.subject_template }}
                            <button type="button" class="btn btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#addTemplateModal" title="Создать новое название">
                                <i class="bi bi-plus-lg"></i>
                            </button>
                        </div>
                    </div>

                    <div class="row g-2 mb-3">
                        <div class="col-6">
                            <label class="form-label small fw-bold text-muted text-uppercase">Цикл</label>
                            {{ form.cycle }}
                        </div>
                        <div class="col-6">
                            <label class="form-label small fw-bold text-muted text-uppercase">Тип</label>
                            {{ form.discipline_type }}
                        </div>
                        <div class="col-12 mt-2">
                            <label class="form-label small fw-bold text-muted text-uppercase">Контроль</label>
                            {{ form.control_type }}
                        </div>
                    </div>

                    <div class="card border-primary shadow-sm mb-3">
                        <div class="card-header bg-primary text-white py-2 d-flex justify-content-between align-items-center">
                            <h6 class="mb-0 small fw-bold"><i class="bi bi-sliders"></i> Конструктор нагрузки</h6>
                            <span class="badge bg-light text-primary" id="add_total_credits_badge">0 ч. всего</span>
                        </div>
                        <div class="card-body p-2 bg-light">
                            <div class="row g-2 mb-2">
                                <div class="col-6">
                                    <label class="small fw-bold text-muted">Система кредитов</label>
                                    <div class="input-group input-group-sm">
                                        <select name="credit_type" id="id_credit_type" class="form-select fw-bold border-primary add-ui-calc">
                                            <option value="" data-hours="24">Стандарт (24ч)</option>
                                            {% for ct in credit_types %}
                                                <option value="{{ ct.id }}" data-hours="{{ ct.hours_per_credit }}">{{ ct.name }}</option>
                                            {% endfor %}
                                        </select>
                                        <button type="button" class="btn btn-outline-primary" onclick="addCreditTypePrompt()"><i class="bi bi-plus"></i></button>
                                    </div>
                                </div>
                                <div class="col-3">
                                    <label class="small fw-bold text-muted">Кредиты</label>
                                    {{ form.credits }}
                                </div>
                                <div class="col-3">
                                    <label class="small fw-bold text-muted">Недель</label>
                                    <input type="number" id="add_ui_weeks" class="form-control form-control-sm text-center fw-bold add-ui-calc" value="16">
                                </div>
                            </div>
                            
                            <label class="small fw-bold text-dark mb-1 d-block border-bottom pb-1 mt-2">Укажите количество ПАР в неделю:</label>
                            <div class="row g-2 mb-2">
                                <div class="col-6">
                                    <label class="small text-muted mb-1"><i class="bi bi-person-video3 text-primary"></i> Лекции</label>
                                    <select id="add_ui_lec" class="form-select form-select-sm border-primary add-ui-calc">

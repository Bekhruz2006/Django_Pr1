                            <tr>
                                <td>{{ order.number }}</td>
                                <td>{{ order.date|date:"d.m.Y" }}</td>
                                <td><span class="badge bg-secondary">{{ order.get_order_type_display }}</span></td>
                                <td>
                                    {% if order.file %}
                                    <a href="{{ order.file.url }}" target="_blank"><i class="bi bi-paperclip"></i></a>
                                    {% endif %}
                                </td>
                            </tr>
                            {% empty %}
                            <tr><td colspan="4" class="text-center text-muted">{% trans "Приказов нет" %}</td></tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
</file>


<file path="templates/accounts/document_templates.html">
{% extends 'base.html' %}
{% load i18n %}

{% block title %}{% trans "Управление шаблонами документов" %}{% endblock %}

{% block breadcrumbs %}
    <li class="breadcrumb-item active">{% trans "Шаблоны документов" %}</li>
{% endblock %}

{% block content %}
<div class="row mt-4">
    <div class="col-lg-4 mb-4">
        <div class="card shadow-sm border-0 sticky-top" style="top: 80px;">
            <div class="card-header bg-primary text-white py-3">
                <h6 class="mb-0"><i class="bi bi-cloud-upload"></i> Загрузить новый шаблон</h6>
            </div>
            <div class="card-body">
                <div class="alert alert-info small">
                    <i class="bi bi-info-circle"></i> Загружайте файлы только в формате <strong>.docx</strong>. 
                    Используйте теги в двойных фигурных скобках, например <code>{{ full_name }}</code>, чтобы система могла подставить данные.
                </div>
                <form method="post" enctype="multipart/form-data">
                    {% csrf_token %}
                    {% for field in form %}
                        <div class="mb-3">
                            <label class="form-label fw-bold small text-muted text-uppercase">{{ field.label }}</label>
                            {{ field }}
                            {% if field.errors %}
                                <div class="text-danger small mt-1">{{ field.errors.0 }}</div>
                            {% endif %}
                        </div>
                    {% endfor %}
                    <button type="submit" class="btn btn-success w-100 fw-bold">
                        <i class="bi bi-save"></i> Сохранить шаблон
                    </button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center border-bottom">
                <h5 class="mb-0 text-dark"><i class="bi bi-files me-2 text-primary"></i>Доступные шаблоны</h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light text-muted small text-uppercase">
                            <tr>
                                <th class="ps-4">Название</th>
                                <th>Тип контекста</th>
                                <th class="text-center">Статус</th>
                                <th class="text-end pe-4">Действия</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for tmpl in templates %}
                            <tr>
                                <td class="ps-4">
                                    <div class="fw-bold text-dark">{{ tmpl.name }}</div>
                                    <small class="text-muted">Загружен: {{ tmpl.created_at|date:"d.m.Y H:i" }}</small>
                                </td>
                                <td>
                                    <span class="badge bg-secondary bg-opacity-10 text-dark border">
                                        {{ tmpl.get_context_type_display }}
                                    </span>
                                </td>
                                <td class="text-center">
                                    {% if tmpl.is_active %}
                                        <span class="badge bg-success">Активен</span>
                                    {% else %}
                                        <span class="badge bg-danger">Отключен</span>
                                    {% endif %}
                                </td>
                                <td class="text-end pe-4">
                                    <a href="{{ tmpl.file.url }}" class="btn btn-sm btn-outline-primary" title="Скачать .docx для проверки">
                                        <i class="bi bi-download"></i>
                                    </a>
                                    <a href="{% url 'accounts:delete_document_template' tmpl.id %}" class="btn btn-sm btn-outline-danger ms-1" onclick="return confirm('Удалить шаблон?')" title="Удалить">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </td>
                            </tr>
                            {% empty %}
                            <tr>
                                <td colspan="4" class="text-center py-5 text-muted">
                                    <i class="bi bi-file-earmark-x display-4 d-block mb-3 opacity-25"></i>
                                    Шаблоны еще не загружены.
                                </td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
</file>


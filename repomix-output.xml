<file path="templates/schedule/global_setup.html">
{% extends 'base.html' %}
{% block title %}Глобальный запуск семестра{% endblock %}
{% block content %}
<div class="row mt-4">
    <div class="col-lg-6 mx-auto">
        <div class="card shadow border-primary">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0"><i class="bi bi-rocket-takeoff"></i> Глобальный запуск учебного периода</h5>
            </div>
            <div class="card-body">
                <div class="alert alert-warning">
                    <strong>Внимание!</strong> Нажатие этой кнопки переведет <b>все текущие семестры в архив</b> и создаст новую сетку для всех факультетов и курсов (с 1 по 5). Журналы начнут работу с чистого листа с указанной даты.
                </div>
                <form method="post" action="{% url 'schedule:global_semester_setup' %}">
                    {% csrf_token %}
                    <div class="mb-3">
                        <label class="form-label fw-bold">Учебный год</label>
                        <input type="text" name="academic_year" class="form-control" value="2025-2026" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Семестр</label>
                        <select name="number" class="form-select">
                            <option value="1">1 (Осенний)</option>
                            <option value="2">2 (Весенний)</option>
                        </select>
                    </div>
                    <div class="row mb-4">
                        <div class="col-6">
                            <label class="form-label fw-bold">Дата начала</label>
                            <input type="date" name="start_date" class="form-control" required>
                        </div>
                        <div class="col-6">
                            <label class="form-label fw-bold">Дата окончания</label>
                            <input type="date" name="end_date" class="form-control" required>
                        </div>
                    </div>
                    <button type="submit" id="launchBtn" class="btn btn-danger w-100 btn-lg fw-bold position-relative overflow-hidden">
                        <span id="btnText"><i class="bi bi-power"></i> Запустить новый семестр</span>
                        <span id="btnLoader" class="d-none">
                            <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                            Генерация расписания и журналов...
                        </span>
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>



<script>
document.querySelector('form').addEventListener('submit', function(e) {
    if(!confirm('Вы абсолютно уверены? Это действие затронет весь университет.')) {
        e.preventDefault();
        return;
    }
    document.getElementById('btnText').classList.add('d-none');
    document.getElementById('btnLoader').classList.remove('d-none');
    document.getElementById('launchBtn').classList.add('disabled');
    document.getElementById('launchBtn').style.opacity = '0.8';
});
</script>

{% endblock %}
</file>

<file path="templates/schedule/group_list.html">
{% extends 'base.html' %}

{% block title %}Список групп{% endblock %}

{% block content %}
<div class="row mt-4">
    <div class="col-12">
        {% for item in groups_with_students %}
        <div class="card mb-4">
            <div class="card-header">
                <i class="bi bi-collection"></i> Группа {{ item.group.name }} - {{ item.group.specialty }}
                <span class="badge bg-primary ms-2">{{ item.group.course }} курс</span>
                <span class="badge bg-info ms-2">{{ item.students|length }} студентов</span>
            </div>
            <div class="card-body">
                {% if item.students %}
                <div class="table-responsive">
                    <table class="table table-hover sortable-table">
                        <thead>
                            <tr>
                                <th onclick="sortTable(this, 0)" class="sortable">№</th>
                                <th onclick="sortTable(this, 1)" class="sortable">ФИО студента</th>
                                <th onclick="sortTable(this, 2)" class="sortable">День рождения</th>
                                <th onclick="sortTable(this, 3)" class="sortable">Последний вход</th>
                                <th onclick="sortTable(this, 4)" class="sortable">Средний балл</th>
                                <th onclick="sortTable(this, 5)" class="sortable">Рейтинг</th>
                            </tr>
                        </thead>
